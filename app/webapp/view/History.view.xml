<mvc:View
    controllerName="timesheet.app.controller.History"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:unified="sap.ui.unified"
    xmlns:core="sap.ui.core"
    displayBlock="true">

    <Page id="historyPage"
          showNavButton="false"
          enableScrolling="true">

        <customHeader>
            <Bar>
                <contentLeft>
                    <Title text="Timesheet History" level="H4" />
                </contentLeft>
                <contentRight>
                    <!-- Only visible after a week is selected -->
                    <Button
                        id="btnChangeWeek"
                        icon="sap-icon://calendar"
                        text="Change Week"
                        type="Transparent"
                        visible="{histView>/weekSelected}"
                        tooltip="Select a different week"
                        press=".onCalendarToggle" />
                </contentRight>
            </Bar>
        </customHeader>

        <content>

            <!-- ① No week selected — centered calendar picker -->
            <VBox visible="{= !${histView>/weekSelected} }" class="tsHistWelcome">
                <VBox alignItems="Center" class="tsHistWelcomeCard">
                    <core:Icon
                        src="sap-icon://calendar"
                        size="2.5rem"
                        color="#3b82f6"
                        class="sapUiSmallMarginBottom" />
                    <Title
                        text="Select a Week"
                        level="H3"
                        class="sapUiTinyMarginBottom" />
                    <Text
                        text="Pick any date — the full week's timesheet will be loaded."
                        textAlign="Center"
                        class="tsHistWelcomeHint sapUiSmallMarginBottom" />
                    <unified:Calendar
                        id="histCenterCalendar"
                        select=".onCalendarSelect" />
                </VBox>
            </VBox>

            <!-- ② Week selected — HTML table rendered by controller -->
            <VBox
                visible="{histView>/weekSelected}"
                class="sapUiSmallMargin">

                <!-- Controller renders HTML table into this container -->
                <VBox id="histTableContainer" width="100%" />

            </VBox>

        </content>
    </Page>

</mvc:View>