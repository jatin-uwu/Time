<mvc:View
    controllerName="timesheet.app.controller.History"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:unified="sap.ui.unified"
    xmlns:core="sap.ui.core"
    displayBlock="true">



            <!-- ① No week selected — centered calendar picker -->
    <Page id="historyPage" showHeader="false" class="tsDashboardPage"
          enableScrolling="false">

        <content>

            <!-- ── Compact page header ─────────────────────────────────── -->
            <HBox class="tsPageHeaderCard tsPageHeaderCardStandalone" alignItems="Center">
                <core:Icon src="sap-icon://history" class="tsPageHeaderIcon sapUiTinyMarginEnd" style="color:#ffffff;font-size:1.25rem;" />
                <Text text="Timesheet History"
                      style="color:#ffffff;font-size:1.05rem;font-weight:700;margin-left:8px;" />
            </HBox>

            <!-- ① No week selected yet: centered calendar -->
            <VBox visible="{= !${histView>/weekSelected} }" class="tsHistWelcome">
                <VBox alignItems="Center" class="tsHistWelcomeCard">
                    <core:Icon
                        src="sap-icon://calendar"
                        size="2.5rem"
                        color="#3b82f6"
                        class="sapUiSmallMarginBottom" />
                    <Title
                        text="Select a Week"
                        level="H3"
                        class="sapUiTinyMarginBottom" />
                    <Text
                        text="Pick any date — the full week's timesheet will be loaded."
                        textAlign="Center"
                        class="tsHistWelcomeHint sapUiSmallMarginBottom" />
                    <unified:Calendar
                        id="histCenterCalendar"
                        select=".onCalendarSelect" />
                </VBox>
            </VBox>

            <!-- ② Week selected — HTML table rendered by controller -->
            <VBox
                visible="{histView>/weekSelected}"
                class="sapUiSmallMargin">

                <!-- Controller renders HTML table into this container -->
                <VBox id="histTableContainer" width="100%" />

            </VBox>

        </content>
    </Page>

</mvc:View>