<mvc:View
    controllerName="timesheet.app.controller.TaskAssignment"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:l="sap.ui.layout"
    xmlns:f="sap.ui.layout.form"
    xmlns:u="sap.ui.unified"
    xmlns:core="sap.ui.core"
    displayBlock="true">

    <Page id="taskAssignPage"
          showHeader="false"
          class="tsDashboardPage"
          enableScrolling="true">

        <content>

            <VBox class="tsTaskAssignWrap">

                <!-- ── Page header ─────────────────────────────────────── -->
                <HBox class="tsPageHeaderCard" alignItems="Center" justifyContent="SpaceBetween">
                    <HBox alignItems="Center">
                        <core:Icon src="sap-icon://create-form" class="tsPageHeaderIcon sapUiTinyMarginEnd" style="color:#ffffff;font-size:1.25rem;" />
                        <Text text="Assign New Task"
                              style="color:#ffffff;font-size:1.05rem;font-weight:700;margin-left:8px;" />
                    </HBox>
                    <ObjectStatus
                        text="{taView>/assignedCount} assigned"
                        state="None"
                        icon="sap-icon://task"
                        style="color:#ffffff;"
                        class="tsHeaderBadge" />
                </HBox>

                <!-- ── Task creation form ── -->
                <Panel headerText="Task Details" class="tsTaskFormPanel" expandable="false">

                    <!-- Task type: Solo (default — unchanged flow) vs Group -->
                    <VBox class="sapUiSmallMarginBegin sapUiSmallMarginTop">
                        <Label text="Task Type" />
                        <SegmentedButton selectedKey="{taView>/form/taskType}" width="280px">
                            <items>
                                <SegmentedButtonItem key="solo"  text="Solo"  icon="sap-icon://person-placeholder" />
                                <SegmentedButtonItem key="group" text="Group" icon="sap-icon://group" />
                            </items>
                        </SegmentedButton>
                    </VBox>

                    <l:Grid defaultSpan="L6 M6 S12" hSpacing="2" vSpacing="1" class="sapUiSmallMargin">

                        <VBox>
                            <Label text="Task Name" required="true" />
                            <Input id="inpTaskName"
                                   value="{taView>/form/taskName}"
                                   placeholder="e.g. Build dashboard widget" />
                        </VBox>

                        <VBox>
                            <Label text="{= ${taView>/form/taskType} === 'group' ? 'Assign To (select 2 or more)' : 'Assign To' }" required="true" />
                            <!-- Solo: single-employee picker (unchanged) -->
                            <Select id="selAssignee"
                                    visible="{= ${taView>/form/taskType} !== 'group' }"
                                    selectedKey="{taView>/form/assignedTo}"
                                    items="{taView>/employees}"
                                    forceSelection="false"
                                    width="100%">
                                <core:Item key="{taView>employeeId}" text="{taView>employeeName} ({taView>designation})" />
                            </Select>
                            <!-- Group: multi-employee picker -->
                            <MultiComboBox id="mcbAssignees"
                                    visible="{= ${taView>/form/taskType} === 'group' }"
                                    selectedKeys="{taView>/form/groupAssignees}"
                                    items="{taView>/employees}"
                                    placeholder="Select 2 or more employees"
                                    width="100%">
                                <core:Item key="{taView>employeeId}" text="{taView>employeeName} ({taView>designation})" />
                            </MultiComboBox>
                        </VBox>

                        <VBox>
                            <Label text="Priority" required="true" />
                            <Select id="selPriority"
                                    selectedKey="{taView>/form/priority}"
                                    width="100%">
                                <core:Item key="High"   text="High" />
                                <core:Item key="Medium" text="Medium" />
                                <core:Item key="Low"    text="Low" />
                            </Select>
                        </VBox>

                        <VBox>
                            <Label text="Start Date" />
                            <DatePicker id="dpStart"
                                        value="{taView>/form/startDate}"
                                        valueFormat="yyyy-MM-dd"
                                        displayFormat="MMM d, yyyy"
                                        width="100%"
                                        showWeekNumbers="false" />
                        </VBox>

                        <!-- Due Date is now mandatory -->
                        <VBox>
                            <Label text="Due Date" required="true" />
                            <DatePicker id="dpDue"
                                        value="{taView>/form/dueDate}"
                                        valueFormat="yyyy-MM-dd"
                                        displayFormat="MMM d, yyyy"
                                        width="100%"
                                        showWeekNumbers="false" />
                        </VBox>

                    </l:Grid>

                    <VBox class="sapUiSmallMargin">
                        <Label text="Description (what has to be done)" required="true" />
                        <TextArea id="taDescription"
                                  value="{taView>/form/taskDescription}"
                                  rows="6"
                                  width="100%"
                                  growing="true"
                                  growingMaxLines="12"
                                  placeholder="Describe the work in detail. This block will appear in the employee's Task Description page." />
                    </VBox>

                    <VBox class="sapUiSmallMargin">
                        <Label text="Attachments (optional) — you can add multiple files" />
                        <u:FileUploader id="uplTaskFile"
                                        name="taskAttachment"
                                        multiple="true"
                                        placeholder="Click 'Browse' to attach reference documents or images"
                                        buttonText="Browse..."
                                        fileType="png,jpg,jpeg,gif,pdf,doc,docx,xls,xlsx,txt"
                                        change=".onTaskFileSelected"
                                        width="100%" />
                        <VBox class="sapUiTinyMarginTop" items="{taView>/form/attachments}">
                            <HBox alignItems="Center">
                                <core:Icon src="sap-icon://attachment" size="0.9rem" color="#3b82f6" />
                                <Text text="{taView>fileName}"
                                      class="tsAttachmentName sapUiTinyMarginBegin" />
                                <Button icon="sap-icon://decline"
                                        type="Transparent"
                                        tooltip="Remove attachment"
                                        press=".onRemoveTaskFile"
                                        class="sapUiTinyMarginBegin" />
                            </HBox>
                        </VBox>
                    </VBox>

                    <HBox justifyContent="End" class="sapUiSmallMargin">
                        <Button text="Reset" type="Transparent" press=".onResetForm" />
                        <!-- Solo assign (unchanged) -->
                        <Button text="Assign"
                                type="Emphasized"
                                icon="sap-icon://accept"
                                visible="{= ${taView>/form/taskType} !== 'group' }"
                                press=".onAssignTask"
                                busy="{taView>/busy}"
                                class="sapUiSmallMarginBegin" />
                        <!-- Group create — enabled only with 2+ assignees -->
                        <Button text="Create Group Task"
                                type="Emphasized"
                                icon="sap-icon://group"
                                visible="{= ${taView>/form/taskType} === 'group' }"
                                enabled="{= ${taView>/form/groupAssignees}.length &gt;= 2 }"
                                press=".onAssignGroupTask"
                                busy="{taView>/busy}"
                                class="sapUiSmallMarginBegin" />
                    </HBox>

                </Panel>

            </VBox>

        </content>
    </Page>

</mvc:View>