<mvc:View
    controllerName="timesheet.app.controller.Dashboard"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:fcard="sap.f.cards"
    xmlns:core="sap.ui.core"
    displayBlock="true">

    <Page id="dashPage" class="tsDashPage" showHeader="false" enableScrolling="true">
        <content>
            <VBox class="tsDashOuter">

                <!-- ── Greeting Row (blue brand header) ── -->
                <HBox justifyContent="SpaceBetween" alignItems="Center" class="tsDashGreetingRow">

                    <core:HTML sanitizeContent="false" content="{dash>/greetingHTML}" />

                    <HBox alignItems="Center" style="gap:12px; flex-shrink:0;">
                        <Button id="activeBtn"
                                text="{dash>/attendanceBtnLabel}"
                                type="Default"
                                press=".onMarkAttendance"
                                enabled="{dash>/attendanceBtnEnabled}"
                                class="tsTeamAttExportBtn sapUiTinyMarginEnd" />

                        <!-- Bell icon with unread badge -->
                        <Button id="notifBellBtn"
                                icon="sap-icon://bell"
                                type="Transparent"
                                press=".onNotificationPress"
                                tooltip="Notifications"
                                class="tsDashBellBtn sapUiTinyMarginEnd">
                            <customData>
                                <BadgeCustomData xmlns="sap.m"
                                                key="badge"
                                                value="{dash>/notifUnreadCount}"
                                                visible="{= !!${dash>/notifUnreadCount} }" />
                            </customData>
                        </Button>

                        <Text text="{dash>/todayLabel}"
                              style="font-size:0.82rem; font-weight:500; color:rgba(255,255,255,0.72); white-space:nowrap;" />
                    </HBox>
                </HBox>

                <!-- Dashboard grid HTML -->
                <core:HTML id="dashGrid" sanitizeContent="false" content="{dash>/dashGridHTML}" />

            </VBox>
        </content>
    </Page>

</mvc:View>