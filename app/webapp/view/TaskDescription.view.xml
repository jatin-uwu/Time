<mvc:View
    controllerName="timesheet.app.controller.TaskDescription"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    displayBlock="true">

    <Page id="taskDescPage"
          showHeader="false"
          class="tsDashboardPage"
          enableScrolling="true">

        <content>

            <VBox class="tsTaskDescWrap sapUiSmallMargin">

                <!-- ── Page header (icon + title + count) ─────────────────── -->
                <HBox class="tsPageHeaderCard" alignItems="Center" justifyContent="SpaceBetween">
                    <HBox alignItems="Center">
                        <Button icon="sap-icon://nav-back"
                                type="Transparent"
                                press=".onNavBack"
                                tooltip="Back to dashboard"
                                class="tsPageBackBtn" />
                        <core:Icon src="sap-icon://wallet" class="tsPageHeaderIcon sapUiTinyMarginEnd" style="color:#ffffff;font-size:1.25rem;" />
                        <Text text="Task Descriptions"
                              style="color:#ffffff;font-size:1.05rem;font-weight:700;margin-left:8px;" />
                    </HBox>
                    <ObjectStatus
                        text="{tdView>/totalLabel}"
                        state="None"
                        inverted="false"
                        icon="sap-icon://task"
                        style="color:#ffffff;"
                        class="tsHeaderBadge" />
                </HBox>

                <!-- ── Filters ────────────────────────────────────────────── -->
                <HBox alignItems="Center" class="tsTaskFilterBar" wrap="Wrap">
                    <SearchField placeholder="Search tasks..."
                                 liveChange=".onSearch"
                                 width="260px"
                                 class="sapUiTinyMarginEnd sapUiTinyMarginBottom" />

                    <!-- Manager-only: preview as employee -->
                    <Select id="selEmployeeView"
                            visible="{= ${appView>/userRole} === 'manager' }"
                            selectedKey="{tdView>/viewAsEmployee}"
                            items="{tdView>/employeeFilterList}"
                            change=".onEmployeeFilterChange"
                            width="220px"
                            tooltip="Preview as employee"
                            class="sapUiTinyMarginEnd sapUiTinyMarginBottom">
                        <core:Item key="{tdView>employeeId}" text="{tdView>employeeName}" />
                    </Select>

                    <!-- Priority filter -->
                    <HBox class="tsTaskPriorityFilter sapUiTinyMarginBottom" alignItems="Center">
                        <Button text="All"
                                type="Transparent"
                                press=".onPriorityFilter"
                                class="{= ${tdView>/priorityFilter} === '' ? 'tsFilterBtn tsFilterBtnActive' : 'tsFilterBtn'}" />
                        <Button text="High"
                                type="Transparent"
                                press=".onPriorityFilter"
                                class="{= ${tdView>/priorityFilter} === 'High' ? 'tsFilterBtn tsFilterBtnActive' : 'tsFilterBtn'}" />
                        <Button text="Medium"
                                type="Transparent"
                                press=".onPriorityFilter"
                                class="{= ${tdView>/priorityFilter} === 'Medium' ? 'tsFilterBtn tsFilterBtnActive' : 'tsFilterBtn'}" />
                        <Button text="Low"
                                type="Transparent"
                                press=".onPriorityFilter"
                                class="{= ${tdView>/priorityFilter} === 'Low' ? 'tsFilterBtn tsFilterBtnActive' : 'tsFilterBtn'}" />
                    </HBox>
                </HBox>

                <!-- ── Empty state ────────────────────────────────────────── -->
                <VBox visible="{= ${tdView>/displayTasks}.length === 0 }"
                      class="tsTaskEmpty sapUiMediumMarginTop"
                      alignItems="Center">
                    <core:Icon src="sap-icon://inbox" size="3rem" color="#9ca3af" />
                    <Text text="No tasks assigned yet."
                          class="sapUiSmallMarginTop"
                          textAlign="Center" />
                    <Text text="Tasks assigned by your manager will appear here, sorted by priority."
                          class="sapUiTinyMarginTop"
                          textAlign="Center" />
                </VBox>

                <!-- ── Task cards ─────────────────────────────────────────── -->
                <List items="{tdView>/displayTasks}"
                      mode="None"
                      showSeparators="None"
                      class="tsTaskCardList"
                      visible="{= ${tdView>/displayTasks}.length > 0 }">

                    <CustomListItem class="tsTaskCardItem">
                        <VBox class="tsTaskCard">

                            <!-- Card header: priority + name + status badge -->
                            <HBox justifyContent="SpaceBetween" alignItems="Center" class="tsTaskCardHeader">
                                <VBox>
                                    <HBox alignItems="Center" wrap="Wrap">
                                        <ObjectStatus
                                            text="{tdView>priority}"
                                            state="{path:'tdView>priority', formatter:'.formatPriorityState'}"
                                            icon="sap-icon://flag" />
                                        <Title text="{tdView>taskName}"
                                               level="H5"
                                               class="sapUiSmallMarginBegin" />
                                        <!-- "For Review" badge — visible whenever the
                                             task is currently In Review.  Helps both
                                             the reviewer and bystanders spot it
                                             immediately. -->
                                        <ObjectStatus
                                            text="For Review"
                                            state="Information"
                                            icon="sap-icon://approvals"
                                            class="sapUiSmallMarginBegin tsForReviewBadge"
                                            visible="{= ${tdView>status} === 'In Review' }" />
                                    </HBox>
                                    <Text text="{tdView>taskId}" class="tsTaskRowId" />
                                </VBox>
                                <HBox alignItems="Center">
                                    <ObjectStatus
                                        text="{tdView>status}"
                                        state="{path:'tdView>status', formatter:'.formatStatusState'}" />
                                    <Button icon="sap-icon://slim-arrow-right"
                                            type="Transparent"
                                            tooltip="Open task details"
                                            press=".onOpenDetails"
                                            class="sapUiTinyMarginBegin tsTaskOpenBtn" />
                                </HBox>
                            </HBox>

                            <!-- Description -->
                            <VBox class="tsTaskDescBlock">
                                <Label text="What has to be done" class="tsTaskDescLabel" />
                                <Text text="{tdView>taskDescription}" class="tsTaskDescText" />
                            </VBox>

                            <!-- Manager attachment (if any) -->
                            <HBox class="tsTaskAttachmentRow"
                                  alignItems="Center"
                                  visible="{= !!${tdView>attachmentName} }">
                                <core:Icon src="sap-icon://attachment" size="0.95rem" color="#3b82f6" />
                                <Text text="Reference document:"
                                      class="tsTaskAttachmentLabel sapUiTinyMarginBegin" />
                                <Link text="{tdView>attachmentName}"
                                      press=".onDownloadTaskAttachment"
                                      class="sapUiTinyMarginBegin" />
                            </HBox>

                            <!-- Reviewer feedback block — visible to the assignee
                                 whenever the task has a latest review. Surfaces
                                 the reviewer's remarks + attachment so the
                                 assignee knows what to fix or why it passed. -->
                            <VBox class="tsReviewFeedback"
                                  visible="{= ${tdView>_isAssignee} === true &amp;&amp; !!${tdView>reviewRemarks} }">
                                <HBox alignItems="Center" class="tsReviewFeedbackHeader">
                                    <core:Icon src="{= ${tdView>reviewDecision} === 'IssueFound' ? 'sap-icon://alert' : 'sap-icon://message-success' }"
                                               size="1rem"
                                               color="{= ${tdView>reviewDecision} === 'IssueFound' ? '#dc2626' : '#16a34a' }" />
                                    <Text text="{= ${tdView>reviewDecision} === 'IssueFound' ? 'Reviewer reported an issue' : 'Reviewer signed off' }"
                                          class="sapUiTinyMarginBegin tsReviewFeedbackTitle" />
                                    <Text text=" — by {tdView>reviewerName} "
                                          class="tsReviewFeedbackBy" />
                                </HBox>
                                <Text text="{tdView>reviewRemarks}"
                                      class="tsReviewFeedbackText sapUiTinyMarginTop"
                                      wrapping="true" />
                                <Link text="Download reviewer attachment ({tdView>reviewAttachmentName})"
                                      press=".onDownloadReviewAttachment"
                                      visible="{= !!${tdView>reviewAttachmentName} }"
                                      class="sapUiTinyMarginTop" />
                            </VBox>

                            <!-- Footer: assignee + due date + reviewer badge -->
                            <HBox class="tsTaskCardFooter" justifyContent="SpaceBetween" alignItems="Center" wrap="Wrap">
                                <HBox alignItems="Center" class="sapUiTinyMarginEnd">
                                    <core:Icon src="sap-icon://employee" size="1rem" color="#6b7280" />
                                    <Text text="{tdView>assigneeName}" class="sapUiTinyMarginBegin" />
                                </HBox>
                                <HBox alignItems="Center" class="sapUiTinyMarginEnd">
                                    <core:Icon src="sap-icon://date-time" size="1rem" color="#6b7280" />
                                    <Text text="{tdView>dueLabel}" class="sapUiTinyMarginBegin" />
                                </HBox>
                                <!-- Reviewer badge — only when a reviewer is assigned -->
                                <HBox alignItems="Center"
                                      visible="{= !!${tdView>reviewerName} }">
                                    <core:Icon src="sap-icon://approvals" size="1rem" color="#6b7280" />
                                    <Text text="Reviewer: " class="sapUiTinyMarginBegin" />
                                    <Text text="{tdView>reviewerName}" class="sapUiTinyMarginBegin" />
                                </HBox>
                            </HBox>

                            <!-- ══ ASSIGNEE action row ════════════════════════════════
                                 visible="_isAssignee" is pre-computed in _applyFilter()
                                 so a simple boolean path binding works — no inline function. -->
                            <HBox class="tsTaskActionRow"
                                  justifyContent="End"
                                  alignItems="Center"
                                  wrap="Wrap"
                                  visible="{tdView>_canEditStatus}">

                                <Label text="Update status:" class="tsTaskActionLabel sapUiTinyMarginEnd" />
                                <Select selectedKey="{path: 'tdView>status', mode: 'OneWay'}"
                                        change=".onStatusChange"
                                        width="160px">
                                    <core:Item key="Not Started" text="Not Started" />
                                    <core:Item key="In Progress" text="In Progress" />
                                    <core:Item key="In Review"   text="In Review"   />
                                    <core:Item key="Completed"   text="Completed"   />
                                </Select>
                            </HBox>

                            <!-- ══ REVIEWER action row ════════════════════════════════
                                 visible="_isReviewerActive" is pre-computed in _applyFilter():
                                 true only when status === "In Review" AND reviewer === currentUser.
                                 Each button opens a dialog (remarks + optional attachment)
                                 — see onOpenReviewedDialog / onOpenIssueDialog. -->
                            <HBox class="tsTaskActionRow tsReviewerActionRow"
                                  justifyContent="End"
                                  alignItems="Center"
                                  wrap="Wrap"
                                  visible="{tdView>_isReviewerActive}">

                                <Label text="Review decision:" class="tsTaskActionLabel sapUiTinyMarginEnd" />
                                <Button text="Mark as Completed"
                                        icon="sap-icon://accept"
                                        type="Accept"
                                        press=".onOpenReviewedDialog"
                                        class="sapUiTinyMarginEnd" />
                                <Button text="Issue Found"
                                        icon="sap-icon://alert"
                                        type="Reject"
                                        press=".onOpenIssueDialog" />
                            </HBox>

                        </VBox>
                    </CustomListItem>

                </List>

            </VBox>

        </content>
    </Page>

</mvc:View>