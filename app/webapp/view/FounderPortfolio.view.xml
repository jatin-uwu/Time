<mvc:View
    controllerName="timesheet.app.controller.FounderPortfolio"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    height="100%">

    <!-- Executive Portfolio Command Center. The controller renders the entire
         premium dashboard (KPIs, health gauge, Chart.js charts, executive table,
         filters, export, drill-down drawer) into the HTML host below from the
         live getPortfolioAnalysis aggregation. Founder-only. -->
    <Page id="portfolioPage" showHeader="false" backgroundDesign="Transparent" class="founderPage">
        <core:HTML id="portfolioHost" content="&lt;div class='fpaRoot'&gt;&lt;div class='fdLoading'&gt;Loading portfolio intelligence…&lt;/div&gt;&lt;/div&gt;" />
    </Page>

</mvc:View>
