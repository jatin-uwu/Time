<mvc:View
    controllerName="timesheet.app.controller.Notifications"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    displayBlock="true">

    <Page id="notificationsPage" class="tsDashboardPage tsNotifPage"
          showHeader="false" enableScrolling="true">
        <content>
            <VBox class="tsNotifWrap">

                <!-- ── Hero header ── -->
                <VBox class="tsNotifHero">
                    <HBox justifyContent="SpaceBetween" alignItems="Center" wrap="Wrap">
                        <VBox>
                            <HBox alignItems="Center">
                                <core:Icon src="sap-icon://bell" class="tsNotifHeroIcon" />
                                <Title text="Notifications" level="H3"
                                       class="tsNotifHeroTitle sapUiTinyMarginBegin" />
                            </HBox>
                            <Text text="{= ${notifView>/unreadCount} > 0
                                ? ${notifView>/unreadCount} + ' unread'
                                : 'You are all caught up' }"
                                  class="tsNotifHeroSub" />
                        </VBox>

                        <HBox alignItems="Center" style="gap:8px;">
                            <Button text="Mark all as read"
                                    type="Emphasized"
                                    icon="sap-icon://accept"
                                    visible="{= ${notifView>/unreadCount} > 0 }"
                                    press=".onMarkAllRead"
                                    class="tsNotifMarkAllBtn" />
                            <!-- Close → Dashboard -->
                            <Button icon="sap-icon://decline"
                                    type="Transparent"
                                    tooltip="Back to Dashboard"
                                    press=".onCloseNotifications" />
                        </HBox>
                    </HBox>
                </VBox>

                <!-- ── Empty state ── -->
                <VBox visible="{= !${notifView>/hasNotifications} }"
                      class="tsNotifEmpty" alignItems="Center">
                    <core:Icon src="sap-icon://bell" size="3rem" color="#d1d5db"
                               class="sapUiSmallMarginBottom" />
                    <Title text="No notifications" level="H4"
                           class="sapUiTinyMarginBottom" />
                    <Text text="You'll be notified here when your manager approves or rejects a timesheet."
                          textAlign="Center" class="tsNotifEmptyHint" />
                </VBox>

                <!-- ── Notification cards ── -->
                <List visible="{notifView>/hasNotifications}"
                      items="{notifView>/notifications}"
                      mode="None"
                      showSeparators="None"
                      class="tsNotifList">

                    <CustomListItem type="Inactive"
                        class="{= ${notifView>isRead} ? 'tsNotifItem tsNotifRead' : 'tsNotifItem tsNotifUnread' }">

                        <HBox class="tsNotifCard" alignItems="Start"
                              justifyContent="SpaceBetween" width="100%">

                            <VBox class="{= ['approved','TIMESHEET_APPROVED','LEAVE_APPROVED'].indexOf(${notifView>type}) >= 0
                                          ? 'tsNotifAccent tsNotifAccentApproved'
                                          : 'tsNotifAccent tsNotifAccentRejected' }" />

                            <HBox alignItems="Start" class="tsNotifMain" width="100%">
                                <VBox class="{path:'notifView>type', formatter:'.formatTypeIconClass'}"
                                      alignItems="Center" justifyContent="Center">
                                    <core:Icon
                                        src="{path:'notifView>type', formatter:'.formatTypeIcon'}"
                                        size="1.2rem" />
                                </VBox>

                                <VBox class="tsNotifBody" width="100%">
                                    <HBox alignItems="Center" class="tsNotifTopRow" width="100%">
                                        <ObjectStatus
                                            text="{path:'notifView>type', formatter:'.formatTypeLabel'}"
                                            state="{path:'notifView>type', formatter:'.formatTypeState'}"
                                            class="tsNotifBadge" />
                                    </HBox>
                                    <Text text="{notifView>title}"
                                          class="sapUiTinyMarginTop"
                                          style="font-weight:600;font-size:0.83rem;color:#111827;"
                                          wrapping="false" />
                                    <Text text="{notifView>message}"
                                          class="tsNotifMessage sapUiTinyMarginTop"
                                          wrapping="true" />
                                </VBox>
                            </HBox>

                            <VBox class="tsNotifMeta" alignItems="End" justifyContent="Start">
                                <HBox alignItems="Center" class="tsNotifWhen">
                                    <core:Icon src="sap-icon://history"
                                               size="0.8rem" color="#9ca3af" />
                                    <Text text="{path:'notifView>notifiedAt', formatter:'.formatTimeAgo'}"
                                          class="tsNotifTime sapUiTinyMarginBegin" />
                                </HBox>
                                <core:Icon src="sap-icon://circle-task-2"
                                           visible="{= !${notifView>isRead} }"
                                           color="#3b82f6" size="0.7rem"
                                           class="tsNotifUnreadDot sapUiTinyMarginTop" />
                            </VBox>

                        </HBox>
                    </CustomListItem>

                </List>

            </VBox>
        </content>
    </Page>

</mvc:View>