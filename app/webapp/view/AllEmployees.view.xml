<mvc:View
    controllerName="timesheet.app.controller.AllEmployees"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:t="sap.ui.table"
    xmlns:core="sap.ui.core"
    displayBlock="true">

    <Page id="allEmpPage" showHeader="false" class="tsHrPage">
        <content>

            <!-- ── Header: title + search + status filter + add ── -->
            <HBox class="tsPageHeaderCard tsPageHeaderCardStandalone" alignItems="Center" justifyContent="SpaceBetween">
                <HBox alignItems="Center">
                    <core:Icon src="sap-icon://employee" class="tsPageHeaderIcon" style="color:#ffffff;font-size:1.25rem;" />
                    <Text text="Directory · {emp>/filtered/length} of {emp>/items/length} employees"
                          style="color:#ffffff;font-size:1.05rem;font-weight:700;margin-left:8px;" />
                </HBox>
                <HBox alignItems="Center">
                    <SearchField id="empSearch"
                                 placeholder="Search by name, email, ID, dept..."
                                 liveChange=".onSearch"
                                 width="260px"
                                 class="tsTeamAttSearch sapUiTinyMarginEnd" />
                    <Select id="statusFilter" selectedKey="all" change=".onStatusFilterChange"
                            width="130px" class="sapUiTinyMarginEnd">
                        <core:Item key="all"      text="All Status" />
                        <core:Item key="Active"   text="Active" />
                        <core:Item key="Inactive" text="Inactive" />
                    </Select>
                    <Button icon="sap-icon://add-employee" text="Add" type="Emphasized"
                            press=".onAdd" class="tsTeamAttExportBtn" />
                </HBox>
            </HBox>

            <!-- ── Body: full-width table with an overlay drawer that slides in ── -->
            <VBox class="tsEmpDirBody">

                <!-- TABLE (always visible) -->
                <t:Table id="empTable"
                         rows="{emp>/filtered}"
                         selectionMode="Single"
                         selectionBehavior="RowOnly"
                         alternateRowColors="true"
                         visibleRowCountMode="Auto"
                         rowSelectionChange=".onRowSelect"
                         class="tsEmpTable">
                    <t:columns>
                        <t:Column width="9%" sortProperty="employeeId">
                            <Label text="ID" />
                            <t:template><Text text="{emp>employeeId}" /></t:template>
                        </t:Column>
                        <t:Column width="18%" sortProperty="employeeName">
                            <Label text="Name" />
                            <t:template><Text text="{emp>employeeName}" /></t:template>
                        </t:Column>
                        <t:Column width="27%" sortProperty="email">
                            <Label text="Email" />
                            <t:template><Text text="{emp>email}" /></t:template>
                        </t:Column>
                        <t:Column width="16%" sortProperty="department">
                            <Label text="Department" />
                            <t:template><Text text="{emp>department}" /></t:template>
                        </t:Column>
                        <t:Column width="18%" sortProperty="designation">
                            <Label text="Designation" />
                            <t:template><Text text="{emp>designation}" /></t:template>
                        </t:Column>
                        <t:Column width="12%" sortProperty="status">
                            <Label text="Status" />
                            <t:template>
                                <ObjectStatus text="{emp>status}"
                                              state="{= ${emp>status} === 'Active' ? 'Success' : ${emp>status} === 'Resigned' ? 'Error' : 'Warning'}" />
                            </t:template>
                        </t:Column>
                    </t:columns>
                </t:Table>

                <!-- DRAWER (overlay, slides in from the right; non-modal) -->
                <VBox id="empDrawer" class="tsEmpDrawer">

                    <!-- Left-edge drag handle (resize) -->
                    <VBox id="empDrawerResizer" class="tsEmpDrawerResizer" />

                    <!-- Drawer header -->
                    <HBox class="tsEmpDrawerHeader" alignItems="Center" justifyContent="SpaceBetween">
                        <HBox alignItems="Center">
                            <Avatar displaySize="M"
                                    initials="{detail>/initials}"
                                    backgroundColor="Accent6"
                                    class="sapUiTinyMarginEnd" />
                            <VBox>
                                <Title text="{detail>/emp/employeeName}" level="H4" class="tsEmpDrawerName" />
                                <Text text="{detail>/emp/designation} · {detail>/emp/department}" class="tsEmpDrawerSub" />
                                <HBox alignItems="Center">
                                    <Text text="ID: {detail>/emp/employeeId}" class="tsEmpDrawerId sapUiTinyMarginEnd" />
                                    <ObjectStatus text="{detail>/emp/status}"
                                                  state="{= ${detail>/emp/status} === 'Active' ? 'Success' : ${detail>/emp/status} === 'Resigned' ? 'Error' : 'Warning'}" />
                                </HBox>
                            </VBox>
                        </HBox>
                        <Button icon="sap-icon://decline" type="Transparent"
                                tooltip="Close" press=".onCloseDrawer" class="tsEmpDrawerClose" />
                    </HBox>

                    <!-- Action buttons (single line) -->
                    <HBox class="tsEmpDrawerActions" alignItems="Center">
                        <Button text="Edit" icon="sap-icon://edit" type="Emphasized"
                                press=".onEditEmployee" />
                        <Button text="{detail>/statusActionText}" icon="{detail>/statusActionIcon}"
                                press=".onToggleStatus" />
                        <Button text="Reset Password" icon="sap-icon://key"
                                press=".onResetPassword" />
                    </HBox>

                    <!-- Scrollable content (CSS flex scroller — reliable in a flex column) -->
                    <VBox class="tsEmpDrawerContent tsEmpDrawerScroll">

                            <Panel headerText="Contact" expandable="true" expanded="true" class="tsEmpDrawerPanel">
                                <VBox class="tsEmpDrawerFields">
                                    <HBox class="tsEmpField"><core:Icon src="sap-icon://email" class="tsEmpFieldIcon" /><VBox><Text text="Email" class="tsEmpFieldLabel" /><Text text="{detail>/emp/email}" class="tsEmpFieldValue" /></VBox></HBox>
                                    <HBox class="tsEmpField"><core:Icon src="sap-icon://phone" class="tsEmpFieldIcon" /><VBox><Text text="Phone" class="tsEmpFieldLabel" /><Text text="{= ${detail>/emp/mobileNumber} || '—' }" class="tsEmpFieldValue" /></VBox></HBox>
                                    <HBox class="tsEmpField"><core:Icon src="sap-icon://addresses" class="tsEmpFieldIcon" /><VBox><Text text="Address" class="tsEmpFieldLabel" /><Text text="{= ${detail>/emp/address} || '—' }" class="tsEmpFieldValue" /></VBox></HBox>
                                    <HBox class="tsEmpField"><core:Icon src="sap-icon://warning" class="tsEmpFieldIcon" /><VBox><Text text="Emergency Contact" class="tsEmpFieldLabel" /><Text text="{= ${detail>/emp/emergencyContact} || '—' }" class="tsEmpFieldValue" /></VBox></HBox>
                                </VBox>
                            </Panel>

                            <Panel headerText="Employment" expandable="true" expanded="true" class="tsEmpDrawerPanel">
                                <VBox class="tsEmpDrawerFields">
                                    <HBox class="tsEmpField"><core:Icon src="sap-icon://manager" class="tsEmpFieldIcon" /><VBox><Text text="Reporting Manager" class="tsEmpFieldLabel" /><Text text="{= ${detail>/managerName} || '—' }" class="tsEmpFieldValue" /></VBox></HBox>
                                    <HBox class="tsEmpField"><core:Icon src="sap-icon://calendar" class="tsEmpFieldIcon" /><VBox><Text text="Date of Joining" class="tsEmpFieldLabel" /><Text text="{= ${detail>/emp/joiningDate} || '—' }" class="tsEmpFieldValue" /></VBox></HBox>
                                    <HBox class="tsEmpField"><core:Icon src="sap-icon://employee-lookup" class="tsEmpFieldIcon" /><VBox><Text text="Employment Type" class="tsEmpFieldLabel" /><Text text="{= ${detail>/emp/employmentType} || '—' }" class="tsEmpFieldValue" /></VBox></HBox>
                                    <HBox class="tsEmpField"><core:Icon src="sap-icon://status-positive" class="tsEmpFieldIcon" /><VBox><Text text="Status" class="tsEmpFieldLabel" /><Text text="{detail>/emp/status}" class="tsEmpFieldValue" /></VBox></HBox>
                                </VBox>
                            </Panel>

                            <Panel headerText="Identity" expandable="true" expanded="true" class="tsEmpDrawerPanel">
                                <VBox class="tsEmpDrawerFields">
                                    <HBox class="tsEmpField"><core:Icon src="sap-icon://birthday-invite" class="tsEmpFieldIcon" /><VBox><Text text="Date of Birth" class="tsEmpFieldLabel" /><Text text="{= ${detail>/emp/dateOfBirth} || '—' }" class="tsEmpFieldValue" /></VBox></HBox>
                                    <HBox class="tsEmpField"><core:Icon src="sap-icon://person-placeholder" class="tsEmpFieldIcon" /><VBox><Text text="Gender" class="tsEmpFieldLabel" /><Text text="{= ${detail>/emp/gender} || '—' }" class="tsEmpFieldValue" /></VBox></HBox>
                                    <HBox class="tsEmpField"><core:Icon src="sap-icon://heart" class="tsEmpFieldIcon" /><VBox><Text text="Blood Group" class="tsEmpFieldLabel" /><Text text="{= ${detail>/emp/bloodGroup} || '—' }" class="tsEmpFieldValue" /></VBox></HBox>
                                </VBox>
                            </Panel>

                            <Panel headerText="Documents ({detail>/docs/length})" expandable="true" expanded="true" class="tsEmpDrawerPanel">
                                <VBox visible="{= ${detail>/docs/length} === 0 }" class="tsEmpNoDocs" alignItems="Center">
                                    <core:Icon src="sap-icon://document" size="1.8rem" color="#9ca3af" />
                                    <Text text="No documents uploaded." class="sapUiTinyMarginTop" />
                                </VBox>
                                <List items="{detail>/docs}" showSeparators="Inner"
                                      visible="{= ${detail>/docs/length} > 0 }">
                                    <CustomListItem class="tsEmpDocItem">
                                        <HBox alignItems="Center" justifyContent="SpaceBetween" class="tsEmpDocRow">
                                            <HBox alignItems="Center">
                                                <core:Icon src="sap-icon://document-text" class="tsEmpDocIcon sapUiTinyMarginEnd" />
                                                <VBox>
                                                    <Text text="{detail>fileName}" class="tsEmpDocName" />
                                                    <Text text="{detail>documentType} · Uploaded {detail>uploadedLabel}" class="tsEmpDocMeta" />
                                                </VBox>
                                            </HBox>
                                            <Button icon="sap-icon://download" type="Transparent"
                                                    tooltip="Download" press=".onDownloadDoc">
                                                <customData>
                                                    <core:CustomData key="documentId" value="{detail>documentId}" />
                                                </customData>
                                            </Button>
                                        </HBox>
                                    </CustomListItem>
                                </List>
                            </Panel>

                    </VBox>
                </VBox>

            </VBox>

        </content>
    </Page>

</mvc:View>
