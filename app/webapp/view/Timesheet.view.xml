<mvc:View
    controllerName="timesheet.app.controller.Timesheet"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:l="sap.ui.layout"
    xmlns:form="sap.ui.layout.form"
    xmlns:core="sap.ui.core"
    xmlns:unified="sap.ui.unified"
    xmlns:table="sap.ui.table"
    displayBlock="true">

    <Page
        id="timesheetPage"
        showNavButton="false"
        backgroundDesign="List">

        <!-- ── Header Bar ──────────────────────────────────────────────────── -->
        <customHeader>
            <Bar>
                <contentLeft>
                    <VBox>
                        <Title text="Weekly Timesheet" level="H2" />
                        <HBox alignItems="Center">
                            <Button
                                id="btnPrevWeekNav"
                                icon="sap-icon://navigation-left-arrow"
                                type="Transparent"
                                visible="{viewModel>/isPrevWeekApproved}"
                                press=".onSwitchToPrevWeek"
                                tooltip="View Previous Week (Manager Approved)" />
                            <Title
                                id="weekRangeTitle"
                                text="{viewModel>/weekRangeLabel}"
                                level="H4"
                                class="sapUiSmallMarginBeginEnd" />
                            <Button
                                id="btnCurrentWeekNav"
                                icon="sap-icon://navigation-right-arrow"
                                type="Transparent"
                                visible="{= ${viewModel>/isViewingPrevWeek} === true }"
                                press=".onSwitchToCurrentWeek"
                                tooltip="Back to Current Week" />
                        </HBox>
                    </VBox>
                </contentLeft>
                <contentRight>
                    <!-- Status badge -->
                    <ObjectStatus
                        id="timesheetStatusBadge"
                        text="{viewModel>/weekStatus}"
                        state="{viewModel>/weekStatusState}"
                        icon="{viewModel>/weekStatusIcon}"
                        class="sapUiSmallMarginEnd" />
                    <Button
                        id="btnSave"
                        text="Save"
                        type="Default"
                        icon="sap-icon://save"
                        press=".onSaveEntries"
                        enabled="{viewModel>/canEdit}" />
                    <Button
                        id="btnSubmit"
                        text="{= ${viewModel>/isViewingPrevWeek} ? 'Save &amp; Submit' : 'Submit for Approval'}"
                        type="Emphasized"
                        icon="sap-icon://paper-plane"
                        press=".onSubmitTimesheet"
                        enabled="{viewModel>/canSubmit}"
                        class="sapUiSmallMarginBegin" />
                </contentRight>
            </Bar>
        </customHeader>

        <content>
            <VBox class="sapUiSmallMargin">

                <!-- ── Info message strip ──────────────────────────────────── -->
                <MessageStrip
                    id="infoStrip"
                    text="{viewModel>/infoMessage}"
                    type="{viewModel>/infoMessageType}"
                    showCloseButton="true"
                    visible="{= !!${viewModel>/infoMessage} }"
                    class="sapUiSmallMarginBottom" />

                <!-- ── Previous week approved banner ───────────────────────── -->
                <MessageStrip
                    visible="{viewModel>/isPrevWeekApproved}"
                    text="Manager has approved filling the previous week. Click the &#x2190; arrow in the header to switch."
                    type="Success"
                    showIcon="true"
                    class="sapUiSmallMarginBottom" />

                <!-- ══════════════════════════════════════════════════════════
                     TIMESHEET GRID
                     The actual table is built dynamically in the controller
                     using sap/ui/core/HTML and placeAt(). The containers
                     below are the anchors the controller writes into.
                     dayHeaderRow and dailyTotalsRow are hidden by controller
                     because the HTML table renders its own header/footer.
                     ══════════════════════════════════════════════════════════ -->
                <Panel
                    id="timesheetGridPanel"
                    backgroundDesign="Transparent"
                    class="sapUiNoContentPadding">

                    <ScrollContainer horizontal="true" vertical="false" width="100%">
                        <VBox id="timesheetGridContainer" width="100%">

                            <!-- Hidden — controller hides these; table renders its own -->
                            <HBox id="dayHeaderRow" visible="false" class="sapUiSmallMarginBottom">
                                <VBox width="220px" class="sapUiSmallMarginEnd">
                                    <Label text="Project / Task" />
                                </VBox>
                                <HBox id="dayHeadersContainer" />
                                <VBox width="80px" class="sapUiSmallMarginBegin">
                                    <Label text="Total" />
                                </VBox>
                            </HBox>

                            <!-- Controller renders HTML table into this VBox -->
                            <VBox id="timesheetRowsContainer" />

                            <!-- Add Row button — shown below the table -->
                            <HBox class="sapUiSmallMarginTop" visible="{viewModel>/canEdit}">
                                <Button
                                    id="btnAddRow"
                                    text="+ Add Project Row"
                                    type="Ghost"
                                    icon="sap-icon://add"
                                    press=".onAddRow" />
                            </HBox>

                            <!-- Hidden — controller uses DOM totals row inside the table -->
                            <HBox id="dailyTotalsRow" visible="false">
                                <VBox width="220px" class="sapUiSmallMarginEnd">
                                    <Text text="Daily Total" />
                                </VBox>
                                <HBox id="dailyTotalsContainer" />
                                <VBox width="80px" class="sapUiSmallMarginBegin">
                                    <Text id="weekTotalLabel" text="0" />
                                </VBox>
                            </HBox>

                        </VBox>
                    </ScrollContainer>
                </Panel>

                <!-- ══════════════════════════════════════════════════════════
                     MISSED DAY HR APPROVAL BUTTONS
                     Built dynamically — one button per missed past weekday
                     that is older than 2 days and has no HR unlock yet
                     ══════════════════════════════════════════════════════════ -->
                <VBox id="missedDayActionsContainer" class="sapUiSmallMarginTop" />

                <!-- ══════════════════════════════════════════════════════════
                     PREVIOUS WEEK SECTION
                     ══════════════════════════════════════════════════════════ -->
                <Panel
                    id="prevWeekPanel"
                    backgroundDesign="Transparent"
                    class="sapUiMediumMarginTop">
                    <HBox
                        justifyContent="SpaceBetween"
                        alignItems="Center"
                        class="sapUiSmallMargin">
                        <VBox>
                            <Title text="Previous Week Timesheet" level="H5" />
                            <Text
                                text="{viewModel>/prevWeekRangeLabel}"
                                class="sapUiSmallMarginTop" />
                        </VBox>
                        <HBox alignItems="Center">
                            <!-- State 1: No request yet -->
                            <Button
                                id="btnRequestPrevWeek"
                                text="Request to Fill Previous Week"
                                type="Default"
                                icon="sap-icon://edit"
                                visible="{viewModel>/showRequestPrevWeekBtn}"
                                press=".onRequestPrevWeekFill" />

                            <!-- State 2: Request pending manager approval -->
                            <ObjectStatus
                                id="prevWeekPendingStatus"
                                text="Approval Pending from Manager"
                                state="Warning"
                                icon="sap-icon://pending"
                                visible="{viewModel>/showPrevWeekPending}" />

                            <!-- State 3: Approved — can now fill previous week -->
                            <Button
                                id="btnFillPrevWeek"
                                text="Fill Previous Week"
                                type="Emphasized"
                                icon="sap-icon://calendar"
                                visible="{viewModel>/showFillPrevWeekBtn}"
                                enabled="{viewModel>/prevWeekFillEnabled}"
                                press=".onSwitchToPrevWeek" />

                            <!-- State 4: Already submitted -->
                            <ObjectStatus
                                id="prevWeekDoneStatus"
                                text="Previous Week Submitted"
                                state="Success"
                                icon="sap-icon://accept"
                                visible="{viewModel>/showPrevWeekDone}" />
                        </HBox>
                    </HBox>
                </Panel>

            </VBox>
        </content>
    </Page>

    <!-- ══════════════════════════════════════════════════════════════════════
         DIALOG: HR Day-Unlock Request
         NOTE: core:ListItem (not core:Item) — ListItem supports additionalText
         ══════════════════════════════════════════════════════════════════════ -->
    <Dialog
        id="hrUnlockDialog"
        title="Request HR Approval to Fill Missed Day"
        contentWidth="480px"
        type="Message">
        <content>
            <VBox class="sapUiSmallMargin">
                <form:SimpleForm layout="ColumnLayout" columnsL="1" columnsM="1">
                    <form:content>
                        <Label text="Missed Date" required="true" />
                        <Input
                            id="hrUnlockDateDisplay"
                            editable="false"
                            value="{hrUnlockModel>/targetDate}" />

                        <Label text="Select HR Approver" required="true" />
                        <Select
                            id="hrApproverSelect"
                            width="100%"
                            selectedKey="{hrUnlockModel>/selectedHrId}"
                            items="{hrListModel>/hrEmployees}">
                            <core:ListItem
                                key="{hrListModel>employeeId}"
                                text="{hrListModel>employeeName}"
                                additionalText="{hrListModel>designation}" />
                        </Select>

                        <Label text="Reason for Missing" />
                        <TextArea
                            id="hrUnlockRemarks"
                            rows="3"
                            width="100%"
                            maxLength="255"
                            value="{hrUnlockModel>/employeeRemarks}"
                            placeholder="Briefly explain why this date was missed..." />
                    </form:content>
                </form:SimpleForm>
                <MessageStrip
                    text="HR will receive an email. Once approved, you can fill this date."
                    type="Information"
                    showIcon="true"
                    showCloseButton="false"
                    class="sapUiSmallMarginTop" />
            </VBox>
        </content>
        <beginButton>
            <Button
                text="Send Request"
                type="Emphasized"
                icon="sap-icon://paper-plane"
                press=".onSubmitHRUnlockRequest" />
        </beginButton>
        <endButton>
            <Button text="Cancel" press=".onCloseHRUnlockDialog" />
        </endButton>
    </Dialog>

    <!-- ══════════════════════════════════════════════════════════════════════
         DIALOG: Request Previous Week Manager Approval
         ══════════════════════════════════════════════════════════════════════ -->
    <Dialog
        id="prevWeekDialog"
        title="Request Previous Week Timesheet Approval"
        contentWidth="460px"
        type="Message">
        <content>
            <VBox class="sapUiSmallMargin">
                <MessageStrip
                    id="prevWeekDialogInfo"
                    text="{prevWeekModel>/infoText}"
                    type="Warning"
                    showIcon="true"
                    showCloseButton="false"
                    class="sapUiSmallMarginBottom" />
                <form:SimpleForm layout="ColumnLayout" columnsL="1" columnsM="1">
                    <form:content>
                        <Label text="Previous Week" />
                        <Input
                            editable="false"
                            value="{prevWeekModel>/weekRangeLabel}" />

                        <Label text="Your Manager" />
                        <Input
                            editable="false"
                            value="{prevWeekModel>/managerName}" />

                        <Label text="Reason (optional)" />
                        <TextArea
                            id="prevWeekRemarks"
                            rows="3"
                            width="100%"
                            maxLength="255"
                            value="{prevWeekModel>/employeeRemarks}"
                            placeholder="Explain why the previous week was not submitted..." />
                    </form:content>
                </form:SimpleForm>
            </VBox>
        </content>
        <beginButton>
            <Button
                text="Send for Approval"
                type="Emphasized"
                icon="sap-icon://paper-plane"
                press=".onConfirmPrevWeekRequest" />
        </beginButton>
        <endButton>
            <Button text="Cancel" press=".onClosePrevWeekDialog" />
        </endButton>
    </Dialog>

</mvc:View>