<mvc:View
    controllerName="timesheet.app.controller.Timesheet"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:l="sap.ui.layout"
    xmlns:form="sap.ui.layout.form"
    xmlns:core="sap.ui.core"
    xmlns:unified="sap.ui.unified"
    xmlns:table="sap.ui.table"
    displayBlock="true">

    <Page
        id="timesheetPage"
        showHeader="false"
        backgroundDesign="List">

        <content>
            <VBox class="sapUiSmallMargin">

                <!-- ── Page header card ────────────────────────────────────── -->
                <HBox class="tsPageHeaderCard" alignItems="Center" justifyContent="SpaceBetween">
                    <HBox alignItems="Center">
                        <core:Icon src="sap-icon://time-entry-request" class="tsPageHeaderIcon sapUiTinyMarginEnd" style="color:#ffffff;font-size:1.25rem;" />
                        <Text text="Weekly Timesheet"
                              style="color:#ffffff;font-size:1.05rem;font-weight:700;margin-left:8px;" />
                    </HBox>
                    <HBox alignItems="Center">
                        <ObjectStatus
                            id="timesheetStatusBadge"
                            text="{viewModel>/weekStatus}"
                            state="None"
                            icon="{viewModel>/weekStatusIcon}"
                            style="color:#ffffff;"
                            class="tsHeaderBadge sapUiSmallMarginEnd" />
                        <Button
                            id="btnSave"
                            text="Save"
                            type="Default"
                            icon="sap-icon://save"
                            press=".onSaveEntries"
                            enabled="{viewModel>/canEdit}"
                            class="tsTeamAttExportBtn" />
                        <Button
                            id="btnSubmit"
                            text="{= ${viewModel>/isViewingPrevWeek} ? 'Save &amp; Submit' : 'Submit for Approval'}"
                            type="Emphasized"
                            icon="sap-icon://paper-plane"
                            press=".onSubmitTimesheet"
                            enabled="{viewModel>/canSubmit}"
                            class="sapUiSmallMarginBegin" />
                    </HBox>
                </HBox>

                <!-- ── Week range navigation ────────────────────────────── -->
                <HBox
                    justifyContent="SpaceBetween"
                    alignItems="Center"
                    class="sapUiSmallMarginBottom">
                    <VBox>
                        <HBox alignItems="Center" class="sapUiTinyMarginTop">
                            <Button
                                id="btnPrevWeekNav"
                                icon="sap-icon://navigation-left-arrow"
                                type="Transparent"
                                visible="{viewModel>/isPrevWeekApproved}"
                                press=".onSwitchToPrevWeek"
                                tooltip="View Previous Week (Manager Approved)" />
                            <Text
                                id="weekRangeTitle"
                                text="{viewModel>/weekRangeLabel}"
                                class="sapUiSmallMarginBeginEnd" />
                            <Button
                                id="btnCurrentWeekNav"
                                icon="sap-icon://navigation-right-arrow"
                                type="Transparent"
                                visible="{= ${viewModel>/isViewingPrevWeek} === true }"
                                press=".onSwitchToCurrentWeek"
                                tooltip="Back to Current Week" />
                        </HBox>
                    </VBox>
                </HBox>

                <!-- ── Info message strip ──────────────────────────────────── -->
                <MessageStrip
                    id="infoStrip"
                    text="{viewModel>/infoMessage}"
                    type="{viewModel>/infoMessageType}"
                    showCloseButton="true"
                    visible="{= !!${viewModel>/infoMessage} }"
                    class="sapUiSmallMarginBottom" />

                <!-- ── Previous week approved banner ───────────────────────── -->
                <MessageStrip
                    visible="{viewModel>/isPrevWeekApproved}"
                    text="Manager has approved filling the previous week. Click the &#x2190; arrow below the title to switch."
                    type="Success"
                    showIcon="true"
                    class="sapUiSmallMarginBottom" />

                <!-- ══════════════════════════════════════════════════════════
                     TIMESHEET GRID
                     ══════════════════════════════════════════════════════════ -->
                <Panel
                    id="timesheetGridPanel"
                    backgroundDesign="Transparent"
                    class="sapUiNoContentPadding">

                    <ScrollContainer horizontal="true" vertical="false" width="100%">
                        <VBox id="timesheetGridContainer" width="100%">

                            <!-- Hidden — controller hides these; table renders its own -->
                            <HBox id="dayHeaderRow" visible="false">
                                <VBox width="220px" class="sapUiSmallMarginEnd">
                                    <Label text="Project / Task" />
                                </VBox>
                                <HBox id="dayHeadersContainer" />
                                <VBox width="80px" class="sapUiSmallMarginBegin">
                                    <Label text="Total" />
                                </VBox>
                            </HBox>

                            <!-- Controller renders HTML table into this VBox -->
                            <VBox id="timesheetRowsContainer" />

                            <!-- Add Row button -->
                            <HBox class="sapUiSmallMarginTop" visible="{viewModel>/canEdit}">
                                <Button
                                    id="btnAddRow"
                                    text="+ Add Project Row"
                                    type="Ghost"
                                    icon="sap-icon://add"
                                    press=".onAddRow" />
                            </HBox>

                            <!-- Hidden totals row — table renders its own -->
                            <HBox id="dailyTotalsRow" visible="false">
                                <VBox width="220px" class="sapUiSmallMarginEnd">
                                    <Text text="Daily Total" />
                                </VBox>
                                <HBox id="dailyTotalsContainer" />
                                <VBox width="80px" class="sapUiSmallMarginBegin">
                                    <Text id="weekTotalLabel" text="0" />
                                </VBox>
                            </HBox>

                        </VBox>
                    </ScrollContainer>
                </Panel>

                <!-- ══════════════════════════════════════════════════════════
                     MISSED DAY HR APPROVAL BUTTONS
                     ══════════════════════════════════════════════════════════ -->
                <VBox id="missedDayActionsContainer" class="sapUiSmallMarginTop" />

                <!-- ══════════════════════════════════════════════════════════
                     PREVIOUS WEEK SECTION — hidden when viewing prev week
                     ══════════════════════════════════════════════════════════ -->
                <HBox id="prevWeekPanel"
                      class="tsPrevWeekCard sapUiMediumMarginTop"
                      alignItems="Center"
                      justifyContent="SpaceBetween"
                      visible="{= !${viewModel>/isViewingPrevWeek} }">

                    <!-- Left: icon + title + date range -->
                    <HBox alignItems="Center">
                        <core:Icon src="sap-icon://calendar"
                                   class="tsPrevWeekIcon" />
                        <VBox class="sapUiTinyMarginBegin">
                            <Title text="Previous Week Timesheet" level="H5"
                                   class="tsPrevWeekTitle" />
                            <Text text="{viewModel>/prevWeekRangeLabel}"
                                  class="tsPrevWeekRange" />
                        </VBox>
                    </HBox>

                    <!-- Right: action / status -->
                    <HBox alignItems="Center">
                        <Button
                            id="btnRequestPrevWeek"
                            text="Request to Fill Previous Week"
                            type="Default"
                            icon="sap-icon://edit"
                            visible="{viewModel>/showRequestPrevWeekBtn}"
                            press=".onRequestPrevWeekFill"
                            class="tsPrevWeekActionBtn" />
                        <HBox alignItems="Center"
                              class="tsPrevWeekPendingBadge"
                              visible="{viewModel>/showPrevWeekPending}">
                            <core:Icon src="sap-icon://pending"
                                       style="color:#d97706;font-size:1rem;" />
                            <Text text="Pending Manager Approval"
                                  class="sapUiTinyMarginBegin"
                                  style="color:#92400e;font-size:0.82rem;font-weight:600;" />
                        </HBox>
                        <Button
                            id="btnFillPrevWeek"
                            text="Fill Previous Week"
                            type="Emphasized"
                            icon="sap-icon://calendar"
                            visible="{viewModel>/showFillPrevWeekBtn}"
                            enabled="{viewModel>/prevWeekFillEnabled}"
                            press=".onSwitchToPrevWeek" />
                        <HBox alignItems="Center"
                              class="tsPrevWeekDoneBadge"
                              visible="{viewModel>/showPrevWeekDone}">
                            <core:Icon src="sap-icon://accept"
                                       style="color:#16a34a;font-size:1rem;" />
                            <Text text="Previous Week Submitted"
                                  class="sapUiTinyMarginBegin"
                                  style="color:#14532d;font-size:0.82rem;font-weight:600;" />
                        </HBox>
                    </HBox>

                </HBox>

            </VBox>
        </content>
    </Page>

    <!-- ══════════════════════════════════════════════════════════════════════
         DIALOG: HR Day-Unlock Request
         ══════════════════════════════════════════════════════════════════════ -->
    <Dialog
        id="hrUnlockDialog"
        title="Request HR Approval to Fill Missed Day"
        contentWidth="480px"
        type="Message">
        <content>
            <VBox class="sapUiSmallMargin">
                <form:SimpleForm layout="ColumnLayout" columnsL="1" columnsM="1">
                    <form:content>
                        <Label text="Missed Date" required="true" />
                        <Input
                            id="hrUnlockDateDisplay"
                            editable="false"
                            value="{hrUnlockModel>/targetDate}" />
                        <Label text="Select HR Approver" required="true" />
                        <Select
                            id="hrApproverSelect"
                            width="100%"
                            selectedKey="{hrUnlockModel>/selectedHrId}"
                            items="{hrListModel>/hrEmployees}">
                            <core:ListItem
                                key="{hrListModel>employeeId}"
                                text="{hrListModel>employeeName}"
                                additionalText="{hrListModel>designation}" />
                        </Select>
                        <Label text="Reason for Missing" />
                        <TextArea
                            id="hrUnlockRemarks"
                            rows="3"
                            width="100%"
                            maxLength="255"
                            value="{hrUnlockModel>/employeeRemarks}"
                            placeholder="Briefly explain why this date was missed..." />
                    </form:content>
                </form:SimpleForm>
                <MessageStrip
                    text="HR will receive an email. Once approved, you can fill this date."
                    type="Information"
                    showIcon="true"
                    showCloseButton="false"
                    class="sapUiSmallMarginTop" />
            </VBox>
        </content>
        <beginButton>
            <Button
                text="Send Request"
                type="Emphasized"
                icon="sap-icon://paper-plane"
                press=".onSubmitHRUnlockRequest" />
        </beginButton>
        <endButton>
            <Button text="Cancel" press=".onCloseHRUnlockDialog" />
        </endButton>
    </Dialog>

    <!-- ══════════════════════════════════════════════════════════════════════
         DIALOG: Request Previous Week Manager Approval
         ══════════════════════════════════════════════════════════════════════ -->
    <Dialog
        id="prevWeekDialog"
        title="Request Previous Week Timesheet Approval"
        contentWidth="460px"
        type="Message">
        <content>
            <VBox class="sapUiSmallMargin">
                <MessageStrip
                    id="prevWeekDialogInfo"
                    text="{prevWeekModel>/infoText}"
                    type="Warning"
                    showIcon="true"
                    showCloseButton="false"
                    class="sapUiSmallMarginBottom" />
                <form:SimpleForm layout="ColumnLayout" columnsL="1" columnsM="1">
                    <form:content>
                        <Label text="Previous Week" />
                        <Input
                            editable="false"
                            value="{prevWeekModel>/weekRangeLabel}" />
                        <Label text="Your Manager" />
                        <Input
                            editable="false"
                            value="{prevWeekModel>/managerName}" />
                        <Label text="Reason (optional)" />
                        <TextArea
                            id="prevWeekRemarks"
                            rows="3"
                            width="100%"
                            maxLength="255"
                            value="{prevWeekModel>/employeeRemarks}"
                            placeholder="Explain why the previous week was not submitted..." />
                    </form:content>
                </form:SimpleForm>
            </VBox>
        </content>
        <beginButton>
            <Button
                text="Send for Approval"
                type="Emphasized"
                icon="sap-icon://paper-plane"
                press=".onConfirmPrevWeekRequest" />
        </beginButton>
        <endButton>
            <Button text="Cancel" press=".onClosePrevWeekDialog" />
        </endButton>
    </Dialog>

</mvc:View>