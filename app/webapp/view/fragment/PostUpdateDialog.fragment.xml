<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:u="timesheet.app.util"
    xmlns:uf="sap.ui.unified">

    <!-- Post a progress update on a group task.
         Uses the app-wide CustomDialog so styling matches every other dialog.
         Model: "gtdView" (the view model). -->
    <u:CustomDialog id="postUpdateDialog"
                    title="Post Update"
                    contentWidth="34rem">
        <u:content>
            <VBox class="sapUiSmallMargin tsPostUpdateBody">

                <Label text="Update title (optional)" class="tsAssignDlgLabel" />
                <Input value="{gtdView>/postForm/title}"
                       maxLength="200"
                       placeholder="e.g. Completed API integration"
                       width="100%" />

                <Label text="Update message" required="true" class="tsAssignDlgLabel sapUiSmallMarginTop" />
                <TextArea value="{gtdView>/postForm/notes}"
                          rows="5"
                          width="100%"
                          growing="true"
                          growingMaxLines="10"
                          maxLength="2000"
                          placeholder="Describe your progress on this task." />

                <Label text="Attachment (optional)" class="tsAssignDlgLabel sapUiSmallMarginTop" />
                <uf:FileUploader id="uplGroupUpdateFile"
                                 name="groupUpdateAttachment"
                                 placeholder="Click 'Browse' to attach a file"
                                 buttonText="Browse..."
                                 fileType="png,jpg,jpeg,gif,pdf,doc,docx,xls,xlsx,ppt,pptx,txt,csv,zip"
                                 change=".onUpdateFileSelected"
                                 width="100%" />
                <HBox alignItems="Center" class="sapUiTinyMarginTop"
                      visible="{= !!${gtdView>/postForm/attachmentName} }">
                    <core:Icon src="sap-icon://attachment" size="0.9rem" color="#3b82f6" />
                    <Text text="{gtdView>/postForm/attachmentName}" class="tsAttachmentName sapUiTinyMarginBegin" />
                    <Button icon="sap-icon://decline" type="Transparent" tooltip="Remove attachment"
                            press=".onClearUpdateAttachment" class="sapUiTinyMarginBegin" />
                </HBox>

            </VBox>
        </u:content>

        <u:beginButton>
            <Button text="Post"
                    type="Emphasized"
                    icon="sap-icon://paper-plane"
                    enabled="{= !${gtdView>/postForm/busy} }"
                    press=".onSubmitUpdate" />
        </u:beginButton>
        <u:endButton>
            <Button text="Cancel" press=".onCancelUpdate" />
        </u:endButton>

    </u:CustomDialog>

</core:FragmentDefinition>
