<mvc:View
    controllerName="timesheet.app.controller.Manager"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:table="sap.ui.table"
    xmlns:core="sap.ui.core"
    displayBlock="true">

    <Page id="managerPage"
          showHeader="false"
          class="tsDashboardPage"
          enableScrolling="true">

        <content>

            <HBox class="tsPageHeaderCard tsPageHeaderCardStandalone" alignItems="Center" justifyContent="SpaceBetween">
                <HBox alignItems="Center">
                    <Button icon="sap-icon://nav-back"
                            type="Transparent"
                            visible="{mgrView>/showDetail}"
                            press=".onNavBack"
                            tooltip="Back"
                            class="tsPageBackBtn" />
                    <core:Icon src="sap-icon://approvals" class="tsPageHeaderIcon sapUiTinyMarginEnd" style="color:#ffffff;font-size:1.25rem;" />
                    <Text text="{mgrView>/pageTitle}"
                          style="color:#ffffff;font-size:1.05rem;font-weight:700;margin-left:8px;" />
                </HBox>
            </HBox>

            <!-- ════════════════════════════════════════════════════════════
                 STATE 1 — Approval queue with two tabs:
                   • Timesheet Approvals
                   • Prev-Week Fill Requests
                 ════════════════════════════════════════════════════════════ -->
            <VBox visible="{= !${mgrView>/showDetail} }" class="tsMgrListView">

                <!-- Section tabs: Timesheets vs Prev-Week -->
                <IconTabBar id="mgrSectionTabs"
                            select=".onSectionTabSelect"
                            selectedKey="timesheets"
                            class="sapUiSmallMarginBottom">
                    <items>
                        <IconTabFilter key="timesheets"
                                       text="Timesheet Approvals"
                                       icon="sap-icon://approvals"
                                       count="{mgrView>/pendingCount}" />
                        <IconTabFilter key="prevweek"
                                       text="Prev-Week Requests"
                                       icon="sap-icon://calendar"
                                       count="{mgrView>/prevWeekPendingCount}" />
                        <IconTabFilter key="leaves"
                                       text="Leave Approvals"
                                       icon="sap-icon://away"
                                       count="{mgrView>/leavePendingCount}" />
                    </items>
                </IconTabBar>

                <!-- ── TAB 1: Timesheet Approvals ──────────────────────── -->
                <VBox visible="{= ${mgrView>/activeSection} === 'timesheets' }">

                    <HBox class="tsMgrListToolbar" alignItems="Center" justifyContent="SpaceBetween">
                        <HBox alignItems="Center">
                            <core:Icon src="sap-icon://approvals" class="tsMgrToolbarIcon" />
                            <Title text="Pending Approvals" level="H4" class="sapUiSmallMarginBegin" />
                        </HBox>
                        <ObjectStatus
                            visible="{= ${mgrView>/pendingCount} > 0 }"
                            text="{mgrView>/pendingCount} pending"
                            state="Warning"
                            icon="sap-icon://alert" />
                    </HBox>

                    <!-- Empty state -->
                    <VBox visible="{= ${mgrView>/submissions}.length === 0 }"
                          class="tsMgrEmptyState" alignItems="Center">
                        <core:Icon src="sap-icon://approvals" size="2.5rem" color="#9ca3af" />
                        <Text text="No pending timesheets." textAlign="Center"
                              class="tsMgrEmptyText sapUiSmallMarginTop" />
                    </VBox>

                    <!-- Table — only when there are items -->
                    <Table id="approvalList"
                           visible="{= ${mgrView>/submissions}.length > 0 }"
                           items="{mgrView>/submissions}"
                           class="sapUiSmallMarginTop">
                        <columns>
                            <Column><Text text="Employee"     /></Column>
                            <Column><Text text="Week"         /></Column>
                            <Column><Text text="Submitted On" /></Column>
                            <Column><Text text="Status"       /></Column>
                            <Column width="14rem"><Text text="Actions" /></Column>
                        </columns>
                        <items>
                            <ColumnListItem>
                                <cells>
                                    <Text text="{mgrView>employeeName}" />
                                    <Text text="{mgrView>weekRange}" />
                                    <Text text="{mgrView>submittedOn}" />
                                    <ObjectStatus
                                        text="{mgrView>status}"
                                        state="{path:'mgrView>status', formatter:'.formatStatusState'}" />
                                    <HBox>
                                        <Button text="Approve"
                                                type="Accept"
                                                icon="sap-icon://accept"
                                                press=".onApproveTimesheetInline"
                                                class="sapUiTinyMarginEnd" />
                                        <Button text="Reject"
                                                type="Reject"
                                                icon="sap-icon://decline"
                                                press=".onRejectTimesheetInline" />
                                    </HBox>
                                </cells>
                            </ColumnListItem>
                        </items>
                    </Table>

                </VBox>

                <!-- ── TAB 2: Prev-Week Fill Requests ─────────────────── -->
                <VBox visible="{= ${mgrView>/activeSection} === 'prevweek' }">

                    <HBox class="tsMgrListToolbar" alignItems="Center" justifyContent="SpaceBetween">
                        <HBox alignItems="Center">
                            <core:Icon src="sap-icon://calendar" class="tsMgrToolbarIcon" />
                            <Title text="Prev-Week Fill Requests" level="H4" class="sapUiSmallMarginBegin" />
                        </HBox>
                        <ObjectStatus
                            visible="{= ${mgrView>/prevWeekPendingCount} > 0 }"
                            text="{mgrView>/prevWeekPendingCount} pending"
                            state="Warning"
                            icon="sap-icon://alert" />
                    </HBox>

                    <!-- Empty state -->
                    <VBox visible="{= ${mgrView>/prevWeekRequests}.length === 0 }"
                          class="tsMgrEmptyState" alignItems="Center">
                        <core:Icon src="sap-icon://calendar" size="2.5rem" color="#9ca3af" />
                        <Text text="No pending prev-week requests." textAlign="Center"
                              class="tsMgrEmptyText sapUiSmallMarginTop" />
                    </VBox>

                    <!-- Table — only when there are items -->
                    <Table id="prevWeekTable"
                           visible="{= ${mgrView>/prevWeekRequests}.length > 0 }"
                           items="{mgrView>/prevWeekRequests}"
                           class="sapUiSmallMarginTop">
                        <columns>
                            <Column><Text text="Employee"        /></Column>
                            <Column><Text text="Week"            /></Column>
                            <Column><Text text="Requested On"    /></Column>
                            <Column><Text text="Employee Remarks"/></Column>
                            <Column><Text text="Status"          /></Column>
                            <Column width="14rem"><Text text="Actions" /></Column>
                        </columns>
                        <items>
                            <ColumnListItem>
                                <cells>
                                    <Text text="{mgrView>employeeName}"     />
                                    <Text text="{mgrView>weekRange}"        />
                                    <Text text="{mgrView>requestedOn}"      />
                                    <Text text="{mgrView>employeeRemarks}"  wrapping="false" maxLines="2" />
                                    <ObjectStatus
                                        text="{mgrView>status}"
                                        state="{path:'mgrView>status', formatter:'.formatStatusState'}" />
                                    <HBox>
                                        <Button text="Approve"
                                                type="Accept"
                                                icon="sap-icon://accept"
                                                visible="{= ${mgrView>status} === 'Pending' }"
                                                press=".onApprovePrevWeek"
                                                class="sapUiTinyMarginEnd" />
                                        <Button text="Reject"
                                                type="Reject"
                                                icon="sap-icon://decline"
                                                visible="{= ${mgrView>status} === 'Pending' }"
                                                press=".onRejectPrevWeek" />
                                    </HBox>
                                </cells>
                            </ColumnListItem>
                        </items>
                    </Table>

                </VBox>

                <!-- ── TAB 3: Leave Approvals ─────────────────────────── -->
                <VBox visible="{= ${mgrView>/activeSection} === 'leaves' }">

                    <HBox class="tsMgrListToolbar" alignItems="Center" justifyContent="SpaceBetween">
                        <HBox alignItems="Center">
                            <core:Icon src="sap-icon://away" class="tsMgrToolbarIcon" />
                            <Title text="Leave Requests" level="H4" class="sapUiSmallMarginBegin" />
                        </HBox>
                        <ObjectStatus
                            visible="{= ${mgrView>/leavePendingCount} > 0 }"
                            text="{mgrView>/leavePendingCount} pending"
                            state="Warning"
                            icon="sap-icon://alert" />
                    </HBox>

                    <!-- Empty state -->
                    <VBox visible="{= ${mgrView>/leaveRequests}.length === 0 }"
                          class="tsMgrEmptyState" alignItems="Center">
                        <core:Icon src="sap-icon://away" size="2.5rem" color="#9ca3af" />
                        <Text text="No pending leave requests." textAlign="Center"
                              class="tsMgrEmptyText sapUiSmallMarginTop" />
                    </VBox>

                    <!-- Table — only when there are items -->
                    <Table id="mgrLeaveTable"
                           visible="{= ${mgrView>/leaveRequests}.length > 0 }"
                           items="{mgrView>/leaveRequests}"
                           class="sapUiSmallMarginTop">
                        <columns>
                            <Column><Text text="Employee"   /></Column>
                            <Column><Text text="Leave Type" /></Column>
                            <Column><Text text="From"       /></Column>
                            <Column><Text text="To"         /></Column>
                            <Column width="4rem"><Text text="Days" /></Column>
                            <Column><Text text="Reason"     /></Column>
                            <Column><Text text="Status"     /></Column>
                            <Column width="14rem"><Text text="Actions" /></Column>
                        </columns>
                        <items>
                            <ColumnListItem>
                                <cells>
                                    <Text text="{mgrView>employeeName}" />
                                    <Text text="{mgrView>leaveType}" />
                                    <Text text="{mgrView>fromDate}" />
                                    <Text text="{mgrView>toDate}" />
                                    <Text text="{mgrView>days}" />
                                    <Text text="{mgrView>reason}" wrapping="false" maxLines="2" />
                                    <ObjectStatus
                                        text="{mgrView>status}"
                                        state="{= ${mgrView>status} === 'Approved' ? 'Success' : ${mgrView>status} === 'Rejected' ? 'Error' : 'Warning'}" />
                                    <HBox>
                                        <Button text="Approve"
                                                type="Accept"
                                                icon="sap-icon://accept"
                                                visible="{= ${mgrView>status} === 'Pending' }"
                                                press=".onApproveLeave"
                                                class="sapUiTinyMarginEnd" />
                                        <Button text="Reject"
                                                type="Reject"
                                                icon="sap-icon://decline"
                                                visible="{= ${mgrView>status} === 'Pending' }"
                                                press=".onRejectLeave" />
                                    </HBox>
                                </cells>
                            </ColumnListItem>
                        </items>
                    </Table>

                </VBox>

            </VBox>

            <!-- ════════════════════════════════════════════════════════════
                 STATE 2 — Full-width timesheet detail + approve/reject
                 ════════════════════════════════════════════════════════════ -->
            <VBox visible="{mgrView>/showDetail}" class="tsMgrDetailView">

                <!-- Detail header -->
                <HBox class="tsMgrDetailHeader" justifyContent="SpaceBetween" alignItems="Center">
                    <VBox>
                        <HBox alignItems="Center">
                            <core:Icon src="sap-icon://employee" size="1.2rem" class="tsMgrDetailIcon" />
                            <Title text="{mgrView>/selectedEmployee}" level="H4" class="sapUiTinyMarginBegin" />
                        </HBox>
                        <HBox alignItems="Center" class="sapUiTinyMarginTop">
                            <Text text="{mgrView>/selectedWeek}" class="tsMgrDetailWeek" />
                            <ObjectStatus
                                text="{mgrView>/selectedStatus}"
                                state="{path:'mgrView>/selectedStatus', formatter:'.formatStatusState'}"
                                class="sapUiSmallMarginBegin" />
                        </HBox>
                        <Text text="Submitted: {mgrView>/selectedSubmittedOn}" class="tsMgrDetailDate" />
                    </VBox>

                    <HBox class="tsMgrActionBtns">
                        <Button text="Approve" type="Accept" icon="sap-icon://accept"
                            enabled="{= ${mgrView>/selectedStatus} === 'Pending' || ${mgrView>/selectedStatus} === 'Submitted' }"
                            press=".onApprove" />
                        <Button text="Reject" type="Reject" icon="sap-icon://decline"
                            enabled="{= ${mgrView>/selectedStatus} === 'Pending' || ${mgrView>/selectedStatus} === 'Submitted' }"
                            press=".onReject"
                            class="sapUiSmallMarginBegin" />
                    </HBox>
                </HBox>

                <!-- Rejection reason strip -->
                <MessageStrip
                    visible="{= !!${mgrView>/selectedRemarks} }"
                    text="{= 'Rejection reason: ' + ${mgrView>/selectedRemarks} }"
                    type="Error"
                    showIcon="true"
                    showCloseButton="false"
                    class="sapUiSmallMarginBeginEnd sapUiSmallMarginBottom" />

                <!-- Read-only timesheet table -->
                <table:Table
                    id="mgrTable"
                    rows="{mgrView>/rows}"
                    visibleRowCountMode="Fixed"
                    visibleRowCount="{mgrView>/rowCount}"
                    selectionMode="None"
                    alternateRowColors="false"
                    fixedColumnCount="1"
                    class="timesheetTable"
                    rowHeight="48">

                    <table:noData>
                        <Text text="No timesheet data." class="sapUiMediumMargin" />
                    </table:noData>

                    <table:columns>

                        <table:Column width="180px">
                            <table:label><Label text="Project / Task" /></table:label>
                            <table:template>
                                <VBox class="tsProjectCell">
                                    <Text text="{mgrView>projectName}"
                                        class="{path:'mgrView>_type', formatter:'.formatProjectClass'}"
                                        wrapping="false" />
                                    <Text text="{mgrView>taskName}" class="tsTaskName" wrapping="false" />
                                </VBox>
                            </table:template>
                        </table:Column>

                        <table:Column hAlign="Center" width="100px">
                            <table:label>
                                <VBox alignItems="Center" class="tsColHeaderBox">
                                    <Text text="{mgrView>/days/0/name}" class="tsDayName" />
                                    <Text text="{mgrView>/days/0/date}" class="tsDayDate" />
                                </VBox>
                            </table:label>
                            <table:template>
                                <Text text="{mgrView>mon}" textAlign="Center"
                                    class="{parts:[{path:'mgrView>mon'},{path:'mgrView>_type'}], formatter:'.formatDayCellClass'}" />
                            </table:template>
                        </table:Column>

                        <table:Column hAlign="Center" width="100px">
                            <table:label>
                                <VBox alignItems="Center" class="tsColHeaderBox">
                                    <Text text="{mgrView>/days/1/name}" class="tsDayName" />
                                    <Text text="{mgrView>/days/1/date}" class="tsDayDate" />
                                </VBox>
                            </table:label>
                            <table:template>
                                <Text text="{mgrView>tue}" textAlign="Center"
                                    class="{parts:[{path:'mgrView>tue'},{path:'mgrView>_type'}], formatter:'.formatDayCellClass'}" />
                            </table:template>
                        </table:Column>

                        <table:Column hAlign="Center" width="100px">
                            <table:label>
                                <VBox alignItems="Center" class="tsColHeaderBox">
                                    <Text text="{mgrView>/days/2/name}" class="tsDayName" />
                                    <Text text="{mgrView>/days/2/date}" class="tsDayDate" />
                                </VBox>
                            </table:label>
                            <table:template>
                                <Text text="{mgrView>wed}" textAlign="Center"
                                    class="{parts:[{path:'mgrView>wed'},{path:'mgrView>_type'}], formatter:'.formatDayCellClass'}" />
                            </table:template>
                        </table:Column>

                        <table:Column hAlign="Center" width="100px">
                            <table:label>
                                <VBox alignItems="Center" class="tsColHeaderBox">
                                    <Text text="{mgrView>/days/3/name}" class="tsDayName" />
                                    <Text text="{mgrView>/days/3/date}" class="tsDayDate" />
                                </VBox>
                            </table:label>
                            <table:template>
                                <Text text="{mgrView>thu}" textAlign="Center"
                                    class="{parts:[{path:'mgrView>thu'},{path:'mgrView>_type'}], formatter:'.formatDayCellClass'}" />
                            </table:template>
                        </table:Column>

                        <table:Column hAlign="Center" width="100px">
                            <table:label>
                                <VBox alignItems="Center" class="tsColHeaderBox">
                                    <Text text="{mgrView>/days/4/name}" class="tsDayName" />
                                    <Text text="{mgrView>/days/4/date}" class="tsDayDate" />
                                </VBox>
                            </table:label>
                            <table:template>
                                <Text text="{mgrView>fri}" textAlign="Center"
                                    class="{parts:[{path:'mgrView>fri'},{path:'mgrView>_type'}], formatter:'.formatDayCellClass'}" />
                            </table:template>
                        </table:Column>

                        <table:Column hAlign="Center" width="100px">
                            <table:label>
                                <VBox alignItems="Center" class="tsColHeaderBox">
                                    <Text text="{mgrView>/days/5/name}" class="tsDayName" />
                                    <Text text="{mgrView>/days/5/date}" class="tsDayDate" />
                                </VBox>
                            </table:label>
                            <table:template>
                                <Text text="{mgrView>sat}" textAlign="Center"
                                    class="{parts:[{path:'mgrView>sat'},{path:'mgrView>_type'}], formatter:'.formatDayCellClass'}" />
                            </table:template>
                        </table:Column>

                        <table:Column hAlign="Center" width="100px">
                            <table:label>
                                <VBox alignItems="Center" class="tsColHeaderBox">
                                    <Text text="{mgrView>/days/6/name}" class="tsDayName" />
                                    <Text text="{mgrView>/days/6/date}" class="tsDayDate" />
                                </VBox>
                            </table:label>
                            <table:template>
                                <Text text="{mgrView>sun}" textAlign="Center"
                                    class="{parts:[{path:'mgrView>sun'},{path:'mgrView>_type'}], formatter:'.formatDayCellClass'}" />
                            </table:template>
                        </table:Column>

                        <table:Column hAlign="Center" width="110px">
                            <table:label><Label text="Week Total(Hrs)" /></table:label>
                            <table:template>
                                <Text text="{mgrView>_weekTotal}" textAlign="Center"
                                    class="{path:'mgrView>_type', formatter:'.formatWeekTotalClass'}" />
                            </table:template>
                        </table:Column>

                    </table:columns>
                </table:Table>

            </VBox>

        </content>
    </Page>

</mvc:View>