<mvc:View
    controllerName="timesheet.app.controller.ApplyLeave"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    displayBlock="true">

    <Page id="applyLeavePage" showHeader="false">
        <content>

            <!-- ── Blue page header ── -->
            <HBox class="tsPageHeaderCard tsPageHeaderCardStandalone"
                alignItems="Center" justifyContent="SpaceBetween">
                <HBox alignItems="Center">
                    <core:Icon src="sap-icon://away"
                        class="tsPageHeaderIcon sapUiTinyMarginEnd"
                        style="color:#ffffff;font-size:1.25rem;" />
                    <Text text="Leave Portal"
                        style="color:#ffffff;font-size:1.05rem;font-weight:700;margin-left:8px;" />
                </HBox>
                <Text text="Apply and track your leave requests"
                    style="color:rgba(255,255,255,0.75);font-size:0.84rem;" />
            </HBox>

            <VBox class="tsLeaveWrap">

                <!-- ══════════════════════════════════════════
                     BALANCE CARDS
                ══════════════════════════════════════════ -->
                <HBox class="tsLeaveBalanceRow">

                    <VBox class="tsLeaveBalCard tsLeaveBalCasual" alignItems="Center">
                        <Title text="{leave>/balance/casual}" level="H1" />
                        <Text text="Casual Leave" />
                        <ObjectStatus text="of 5 days" state="None" />
                    </VBox>

                    <VBox class="tsLeaveBalCard tsLeaveBalSick" alignItems="Center">
                        <Title text="{leave>/balance/sick}" level="H1" />
                        <Text text="Sick Leave" />
                        <ObjectStatus text="of 5 days" state="None" />
                    </VBox>

                    <VBox class="tsLeaveBalCard tsLeaveBalPaid" alignItems="Center">
                        <Title text="{leave>/balance/paid}" level="H1" />
                        <Text text="Paid Leave" />
                        <ObjectStatus text="of 11 days" state="None" />
                    </VBox>

                    <VBox class="tsLeaveBalCard tsLeaveBalMaternity" alignItems="Center"
                        visible="{= ${appView>/userRole} !== 'manager' &amp;&amp; ${leave>/showMaternity} }">
                        <Title text="{leave>/balance/maternity}" level="H1" />
                        <Text text="Maternity Leave" />
                        <ObjectStatus text="of 180 days" state="None" />
                    </VBox>

                    <VBox class="tsLeaveBalCard tsLeaveBalPaternity" alignItems="Center"
                        visible="{leave>/showPaternity}">
                        <Title text="{leave>/balance/paternity}" level="H1" />
                        <Text text="Paternity Leave" />
                        <ObjectStatus text="of 2 days" state="None" />
                    </VBox>

                </HBox>

                <!-- ══════════════════════════════════════════
                     APPLY FOR LEAVE FORM
                ══════════════════════════════════════════ -->
                <VBox class="tsLeaveFormCard">

                    <!-- Section header -->
                    <HBox alignItems="Center" class="tsLeaveFormHead">
                        <core:Icon src="sap-icon://add-activity" />
                        <Title text="Apply for Leave" level="H4" />
                    </HBox>

                    <!-- ── ROW 1: Leave Type | Working Days | From Date | To Date ── -->
                    <HBox class="tsLeaveFormRow1">

                        <VBox class="tsLeaveFormField">
                            <Label text="Leave Type" required="true" class="tsLeaveFormLabel" />
                            <Select id="selLeaveType"
                                width="100%"
                                selectedKey="{leave>/form/leaveType}"
                                change=".onLeaveTypeChange">
                                <core:Item key="" text="— Select —" />
                                <core:Item key="Casual" text="Casual Leave (5 days/year)" />
                                <core:Item key="Sick" text="Sick Leave (5 days/year)" />
                                <core:Item key="Paid" text="Paid Leave (11 days/year)" />
                                <core:Item key="Maternity" text="Maternity Leave (180 days)" />
                                <core:Item key="Paternity" text="Paternity Leave (2 days)" />
                            </Select>
                        </VBox>

                        <VBox class="tsLeaveFormField">
                            <Label text="Working Days" class="tsLeaveFormLabel" />
                            <HBox alignItems="Center" class="tsLeaveDaysBox">
                                <ObjectStatus
                                    id="daysCount"
                                    text="{= ${leave>/form/days} > 0 ? ${leave>/form/days} + ' working day(s)' : '—' }"
                                    state="{= ${leave>/form/isUnpaid} ? 'Error' : 'Success' }" />
                            </HBox>
                        </VBox>

                        <VBox class="tsLeaveFormField">
                            <Label text="From Date" required="true" class="tsLeaveFormLabel" />
                            <DatePicker id="dpFrom"
                                value="{leave>/form/fromDate}"
                                valueFormat="yyyy-MM-dd"
                                displayFormat="MMM d, yyyy"
                                width="100%"
                                showWeekNumbers="false"
                                change=".onDateChange" />
                        </VBox>

                        <VBox class="tsLeaveFormField">
                            <Label text="To Date" required="true" class="tsLeaveFormLabel" />
                            <DatePicker id="dpTo"
                                value="{leave>/form/toDate}"
                                valueFormat="yyyy-MM-dd"
                                displayFormat="MMM d, yyyy"
                                width="100%"
                                showWeekNumbers="false"
                                change=".onDateChange" />
                        </VBox>

                    </HBox>

                    <!-- ── ROW 2: Reason (grows) + Buttons pinned bottom-right ── -->
                    <HBox class="tsLeaveFormRow2" alignItems="End">

                        <VBox class="tsLeaveFormFieldReason">
                            <Label text="Reason" required="true" class="tsLeaveFormLabel" />
                            <TextArea id="taReason"
                                value="{leave>/form/reason}"
                                rows="4"
                                maxLength="500"
                                width="100%"
                                placeholder="Brief reason for leave..." />
                        </VBox>

                        <VBox class="tsLeaveFormActions" justifyContent="End">
                            <Button text="Reset"
                                press=".onReset"
                                class="sapUiTinyMarginBottom" />
                            <Button text="Submit Leave Request"
                                type="Emphasized"
                                icon="sap-icon://paper-plane"
                                press=".onSubmit"
                                busy="{leave>/submitting}" />
                        </VBox>

                    </HBox>

                    <!-- ── Cascade warning (Sick leave) ── -->
                    <VBox
                        visible="{= ${leave>/form/leaveType} === 'Sick' &amp;&amp;
                                      ${leave>/form/cascade} !== null &amp;&amp;
                                      ( (${leave>/form/cascade/casual} || 0) +
                                        (${leave>/form/cascade/paid}   || 0) +
                                        (${leave>/form/cascade/unpaid} || 0) ) > 0 }">
                        <MessageStrip
                            text="{= 'Sick Leave balance is insufficient. Excess days will be drawn from: ' +
                                     ( (${leave>/form/cascade/casual} || 0) > 0 ? (${leave>/form/cascade/casual}) + ' day(s) Casual  ' : '' ) +
                                     ( (${leave>/form/cascade/paid}   || 0) > 0 ? (${leave>/form/cascade/paid})   + ' day(s) Paid  '   : '' ) +
                                     ( (${leave>/form/cascade/unpaid} || 0) > 0 ? (${leave>/form/cascade/unpaid}) + ' day(s) Unpaid'    : '' ) }"
                            type="Warning"
                            showIcon="true"
                            showCloseButton="false" />
                    </VBox>

                    <!-- ── Unpaid warning (non-Sick) ── -->
                    <VBox
                        visible="{= ${leave>/form/isUnpaid} &amp;&amp;
                                      ${leave>/form/leaveType} !== 'Sick' }">
                        <MessageStrip
                            text="⚠ Your leave balance is insufficient. Excess days will be marked as Unpaid Leave."
                            type="Warning"
                            showIcon="true"
                            showCloseButton="false" />
                    </VBox>

                </VBox>

                <!-- Leave History section removed — see the dedicated Leave History page. -->

            </VBox>

        </content>
    </Page>

</mvc:View>