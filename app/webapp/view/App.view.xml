<mvc:View
    controllerName="timesheet.app.controller.App"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:core="sap.ui.core"
    displayBlock="true">


<Toolbar style="background:#1e293b; min-height:72px; padding:8px 16px;">

    <Button id="menuToggleBtn"
        icon="sap-icon://menu2"
        type="Transparent"
        press=".onMenuToggle"
        style="color:#ffffff; margin-right:8px;" />

    <!-- Logo -->
    <core:HTML sanitizeContent="false" content="
        &lt;div style='width:44px;height:44px;border-radius:12px;
                     background:linear-gradient(135deg,#3b82f6,#6366f1);
                     display:flex;align-items:center;justify-content:center;
                     flex-shrink:0;margin-right:12px;'&gt;
            &lt;svg width='26' height='26' viewBox='0 0 24 24' fill='none'
                 stroke='white' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'&gt;
                &lt;rect x='2' y='7' width='20' height='14' rx='2'/&gt;
                &lt;path d='M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2'/&gt;
                &lt;line x1='12' y1='12' x2='12' y2='16'/&gt;
                &lt;line x1='10' y1='14' x2='14' y2='14'/&gt;
            &lt;/svg&gt;
        &lt;/div&gt;" />

    <!-- Title + subtitle -->
    <core:HTML sanitizeContent="false" content="
        &lt;div style='display:flex;flex-direction:column;justify-content:center;'&gt;
            &lt;span style='color:#ffffff;font-size:1.15rem;font-weight:700;
                          letter-spacing:1px;font-family:sans-serif;
                          line-height:1.3;'&gt;Employee Dashboard&lt;/span&gt;
            &lt;span style='color:#94a3b8;font-size:0.75rem;font-family:sans-serif;
                          letter-spacing:0.5px;margin-top:2px;'&gt;Ccentrik Technologies&lt;/span&gt;
        &lt;/div&gt;" />

    <ToolbarSpacer />
        <Avatar initials="{= ${appView>/userInitials} || 'JD' }"
            displaySize="XS"
            press=".onProfilePress"
            tooltip="My profile" />
    </Toolbar>

    <SplitApp id="app">

        <masterPages>
            <Page id="navPage" showHeader="false"
                class="timesheetSidebar"
                backgroundDesign="Transparent">

                <!-- Unified navigation -->
                <List id="mainNavList"
                    mode="None"
                    backgroundDesign="Transparent"
                    style="background:transparent;">
                    <items>
                        <StandardListItem title="Overview"
                            icon="sap-icon://home"
                            type="Active"
                            press=".onNavSelect"
                            style="background:transparent; color:#cbd5e1;">
                            <customData>
                                <core:CustomData key="target" value="dashboard" />
                            </customData>
                        </StandardListItem>
                        <StandardListItem title="Timesheet"
                            icon="sap-icon://calendar"
                            type="Active"
                            press=".onNavSelect"
                            style="background:transparent; color:#cbd5e1;">
                            <customData>
                                <core:CustomData key="target" value="timesheet" />
                            </customData>
                        </StandardListItem>
                        <StandardListItem title="Task Descriptions"
                            icon="sap-icon://wallet"
                            type="Active"
                            press=".onNavSelect"
                            style="background:transparent; color:#cbd5e1;">
                            <customData>
                                <core:CustomData key="target" value="task-description" />
                            </customData>
                        </StandardListItem>
                        <StandardListItem title="Apply Leave"
                            icon="sap-icon://away"
                            type="Active"
                            press=".onNavSelect"
                            style="background:transparent; color:#cbd5e1;">
                            <customData>
                                <core:CustomData key="target" value="apply-leave" />
                            </customData>
                        </StandardListItem>
                        <StandardListItem title="Timesheet History"
                            icon="sap-icon://history"
                            type="Active"
                            press=".onNavSelect"
                            style="background:transparent; color:#cbd5e1;">
                            <customData>
                                <core:CustomData key="target" value="history" />
                            </customData>
                        </StandardListItem>
                        <StandardListItem title="Notifications"
                            icon="sap-icon://bell"
                            type="Active"
                            info="{= ${appView>/unreadCount} > 0 ? String(${appView>/unreadCount}) : '' }"
                            infoState="Error"
                            press=".onNavSelect"
                            style="background:transparent; color:#cbd5e1;">
                            <customData>
                                <core:CustomData key="target" value="notifications" />
                            </customData>
                        </StandardListItem>
                        <StandardListItem title="Approvals"
                            icon="sap-icon://approvals"
                            type="Active"
                            press=".onNavSelect"
                            visible="{= ${appView>/userRole} === 'manager'}"
                            style="background:transparent; color:#cbd5e1;">
                            <customData>
                                <core:CustomData key="target" value="manager" />
                            </customData>
                        </StandardListItem>
                        <StandardListItem title="Assign Task"
                            icon="sap-icon://create-form"
                            type="Active"
                            press=".onNavSelect"
                            visible="{= ${appView>/userRole} === 'manager'}"
                            style="background:transparent; color:#cbd5e1;">
                            <customData>
                                <core:CustomData key="target" value="task-assignment" />
                            </customData>
                        </StandardListItem>
                        <StandardListItem title="Task Status"
                            icon="sap-icon://activity-items"
                            type="Active"
                            press=".onNavSelect"
                            visible="{= ${appView>/userRole} === 'manager'}"
                            style="background:transparent; color:#cbd5e1;">
                            <customData>
                                <core:CustomData key="target" value="task-status" />
                            </customData>
                        </StandardListItem>
                        <StandardListItem
                            id="navPerfRating"
                            title="Performance Rating"
                            icon="sap-icon://survey"
                            press=".onNavPerfRating"
                            visible="{= ${app>/role} === 'manager' }" />
                        <StandardListItem title="Leave Approvals"
                            icon="sap-icon://away"
                            type="Active"
                            press=".onNavSelect"
                            visible="{= ${appView>/userRole} === 'manager'}"
                            style="background:transparent; color:#cbd5e1;">
                            <customData>
                                <core:CustomData key="target" value="leave-approvals" />
                            </customData>
                        </StandardListItem>

                        <!-- HR-only entries -->
                        <StandardListItem title="Add Employee"
                            icon="sap-icon://add-employee"
                            type="Active"
                            press=".onNavSelect"
                            visible="{= ${appView>/userRole} === 'hr'}"
                            style="background:transparent; color:#cbd5e1;">
                            <customData>
                                <core:CustomData key="target" value="add-employee" />
                            </customData>
                        </StandardListItem>
                        <StandardListItem title="All Employees"
                            icon="sap-icon://employee"
                            type="Active"
                            press=".onNavSelect"
                            visible="{= ${appView>/userRole} === 'hr'}"
                            style="background:transparent; color:#cbd5e1;">
                            <customData>
                                <core:CustomData key="target" value="all-employees" />
                            </customData>
                        </StandardListItem>
                    </items>
                </List>

                <!-- Empty placeholder kept so existing code referencing managerNavList still
                resolves safely -->
                <List id="managerNavList"
                    mode="None"
                    backgroundDesign="Transparent"
                    visible="false"
                    style="background:transparent;" />

            </Page>
        </masterPages>

        <detailPages>
            <NavContainer id="detailNav" />
        </detailPages>

    </SplitApp>

</mvc:View>