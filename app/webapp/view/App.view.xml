<mvc:View
    controllerName="timesheet.app.controller.App"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:core="sap.ui.core"
    displayBlock="true">

<!-- ── Centred loading screen ─────────────────────────────────────
     Visible from the moment the app starts until the backend has
     confirmed the logged-in user's role.  This guarantees the user
     never sees the sidebar in a partially-styled "wrong role"
     intermediate state on first login. -->
<VBox visible="{= !${appView>/roleResolved} }"
      height="100vh"
      justifyContent="Center"
      alignItems="Center"
      class="tsAppLoading">
    <BusyIndicator size="3rem" />
    <Text text="Loading your workspace…" class="sapUiMediumMarginTop tsAppLoadingText" />
</VBox>

<Toolbar visible="{appView>/roleResolved}"
         style="background:#1e293b; min-height:72px; padding:0px 20px; box-shadow:0 2px 12px rgba(0,0,0,0.35);">

    <Button id="menuToggleBtn"
        icon="sap-icon://menu2"
        type="Transparent"
        press=".onMenuToggle"
        style="color:#ffffff; margin-right:8px;" />

    <!-- Logo -->
    <core:HTML sanitizeContent="false" content="
        &lt;div style='display:flex;align-items:center;gap:10px;margin-right:18px;'&gt;
            &lt;img src='./images/companylogo.jpg'
                 style='height:42px;width:auto;object-fit:contain;background:#ffffff;border-radius:6px;padding:3px 6px;'
                 alt='Centrik Logo' /&gt;
        &lt;/div&gt;" />

    <!-- Title + subtitle -->
    <core:HTML sanitizeContent="false" content="
        &lt;div style='
            display:flex;
            flex-direction:column;
            justify-content:center;
            border-left:2px solid #334155;
            padding-left:16px;
        '&gt;
            &lt;span style='
                color:color:#f1f5f9;
                font-size:0.82rem;
                font-weight:800;
                letter-spacing:3.5px;
                font-family: Trebuchet MS, sans-serif;
                text-transform:uppercase;
                line-height:1.2;
            '&gt;DASHBOARD&lt;/span&gt;
            &lt;span style='
                color:#3b82f6;
                font-size:0.68rem;
                font-family:sans-serif;
                letter-spacing:1.5px;
                margin-top:3px;
                font-weight:500;
            '&gt;CCENTRIK INFOTECH PVT. LTD.&lt;/span&gt;
        &lt;/div&gt;" />

    <ToolbarSpacer />
        <!-- Upload profile picture button -->
        <Button
            icon="sap-icon://camera"
            type="Transparent"
            tooltip="Upload profile picture"
            press=".onUploadProfilePicture" />
        <Avatar id="userAvatar"
        src="{appView>/profilePhotoSrc}"
        initials="{= ${appView>/profilePhotoSrc} ? '' : (${appView>/userInitials} || 'JD') }"
        backgroundColor="{= ${appView>/profilePhotoSrc} ? 'Transparent' : 'Accent6' }"
        displaySize="XS"
        press=".onProfilePress"
        tooltip="My profile" />
    </Toolbar>

    <SplitApp id="app" visible="{appView>/roleResolved}">

        <masterPages>
            <Page id="navPage" showHeader="false"
                class="timesheetSidebar tsSideNav"
                backgroundDesign="Transparent">

                <!-- ── Workspace / role badge ─────────────────────────────── -->
                <VBox class="tsSideHeader">
                    <Text text="WORKSPACE" class="tsSideKicker" />
                    <HBox alignItems="Center" class="tsSideRoleRow">
                        <core:Icon class="tsSideRoleIcon"
                            src="{= ${appView>/userRole} === 'manager' ? 'sap-icon://manager' : (${appView>/userRole} === 'hr' ? 'sap-icon://employee' : 'sap-icon://person-placeholder') }" />
                        <Text class="tsSideRoleText"
                            text="{= ${appView>/userRole} === 'manager' ? 'Manager' : (${appView>/userRole} === 'hr' ? 'HR Admin' : 'Employee') }" />
                    </HBox>
                </VBox>

                <!-- ── Overview (standalone) ──────────────────────────────── -->
                <List id="navOverviewList" mode="None" backgroundDesign="Transparent" class="tsNavList">
                    <StandardListItem title="Overview" icon="sap-icon://home"
                        type="Active" press=".onNavSelect" class="tsNavItem">
                        <customData><core:CustomData key="target" value="dashboard" /></customData>
                    </StandardListItem>
                </List>

                <!-- ── Group: Timesheet ───────────────────────────────────── -->
                <Button class="tsNavGroupHeader" type="Transparent" width="100%" iconFirst="false"
                    text="Timesheet" press=".onToggleGroup"
                    icon="{= ${side>/timesheetOpen} ? 'sap-icon://slim-arrow-down' : 'sap-icon://slim-arrow-right' }">
                    <customData><core:CustomData key="group" value="timesheet" /></customData>
                </Button>
                <VBox id="navTimesheetBody" class="tsNavGroupBody">
                    <List id="navTimesheetList" mode="None" backgroundDesign="Transparent" class="tsNavList">
                        <StandardListItem title="Fill Timesheet" icon="sap-icon://add-activity"
                            type="Active" press=".onNavSelect" class="tsNavItem">
                            <customData><core:CustomData key="target" value="timesheet" /></customData>
                        </StandardListItem>
                        <StandardListItem title="Timesheet History" icon="sap-icon://history"
                            type="Active" press=".onNavSelect" class="tsNavItem">
                            <customData><core:CustomData key="target" value="history" /></customData>
                        </StandardListItem>
                    </List>
                </VBox>

                <!-- ── Group: Leave ───────────────────────────────────────── -->
                <Button class="tsNavGroupHeader" type="Transparent" width="100%" iconFirst="false"
                    text="Leave" press=".onToggleGroup"
                    icon="{= ${side>/leaveOpen} ? 'sap-icon://slim-arrow-down' : 'sap-icon://slim-arrow-right' }">
                    <customData><core:CustomData key="group" value="leave" /></customData>
                </Button>
                <VBox id="navLeaveBody" class="tsNavGroupBody">
                    <List id="navLeaveList" mode="None" backgroundDesign="Transparent" class="tsNavList">
                        <StandardListItem title="Apply Leave" icon="sap-icon://away"
                            type="Active" press=".onNavSelect" class="tsNavItem">
                            <customData><core:CustomData key="target" value="apply-leave" /></customData>
                        </StandardListItem>
                        <StandardListItem title="Leave History" icon="sap-icon://appointment-2"
                            type="Active" press=".onNavSelect" class="tsNavItem">
                            <customData><core:CustomData key="target" value="leave-history" /></customData>
                        </StandardListItem>
                    </List>
                </VBox>

                <!-- ── Group: Task ────────────────────────────────────────── -->
                <Button class="tsNavGroupHeader" type="Transparent" width="100%" iconFirst="false"
                    text="Task" press=".onToggleGroup"
                    icon="{= ${side>/taskOpen} ? 'sap-icon://slim-arrow-down' : 'sap-icon://slim-arrow-right' }">
                    <customData><core:CustomData key="group" value="task" /></customData>
                </Button>
                <VBox id="navTaskBody" class="tsNavGroupBody">
                    <List id="navTaskList" mode="None" backgroundDesign="Transparent" class="tsNavList">
                        <StandardListItem title="Task Description" icon="sap-icon://notes"
                            type="Active" press=".onNavSelect" class="tsNavItem">
                            <customData><core:CustomData key="target" value="task-description" /></customData>
                        </StandardListItem>
                        <StandardListItem title="Task Status" icon="sap-icon://activity-items"
                            type="Active" press=".onNavSelect" class="tsNavItem">
                            <customData><core:CustomData key="target" value="task-status" /></customData>
                        </StandardListItem>
                    </List>
                </VBox>

                <!-- ── Rating History (standalone, outside Task group) ────── -->
                <List id="navRatingList" mode="None" backgroundDesign="Transparent" class="tsNavList">
                    <StandardListItem title="Rating History" icon="sap-icon://survey"
                        type="Active" press=".onNavSelect" class="tsNavItem">
                        <customData><core:CustomData key="target" value="rating-history" /></customData>
                    </StandardListItem>
                </List>

                <!-- ── Group: Management (manager only) ───────────────────── -->
                <Button class="tsNavGroupHeader tsNavGroupHeaderMgr" type="Transparent" width="100%" iconFirst="false"
                    text="Management" press=".onToggleGroup"
                    visible="{= ${appView>/roleResolved} === true &amp;&amp; ${appView>/userRole} === 'manager'}"
                    icon="{= ${side>/managerOpen} ? 'sap-icon://slim-arrow-down' : 'sap-icon://slim-arrow-right' }">
                    <customData><core:CustomData key="group" value="manager" /></customData>
                </Button>
                <VBox id="navManagerBody" class="tsNavGroupBody"
                    visible="{= ${appView>/roleResolved} === true &amp;&amp; ${appView>/userRole} === 'manager'}">
                    <List id="navManagerList" mode="None" backgroundDesign="Transparent" class="tsNavList">
                        <StandardListItem title="Assign Task" icon="sap-icon://create-form"
                            type="Active" press=".onNavSelect" class="tsNavItem">
                            <customData><core:CustomData key="target" value="task-assignment" /></customData>
                        </StandardListItem>
                        <StandardListItem title="Approvals" icon="sap-icon://approvals"
                            type="Active" press=".onNavSelect" class="tsNavItem">
                            <customData><core:CustomData key="target" value="manager" /></customData>
                        </StandardListItem>
                        <StandardListItem title="Approval History" icon="sap-icon://history"
                            type="Active" press=".onNavSelect" class="tsNavItem">
                            <customData><core:CustomData key="target" value="approval-history" /></customData>
                        </StandardListItem>
                        <StandardListItem title="Team Attendance" icon="sap-icon://employee-pane"
                            type="Active" press=".onNavSelect" class="tsNavItem">
                            <customData><core:CustomData key="target" value="team-attendance" /></customData>
                        </StandardListItem>
                        <StandardListItem id="navPerfRating" title="Performance Rating" icon="sap-icon://line-chart"
                            type="Active" press=".onNavPerfRating" class="tsNavItem">
                            <customData><core:CustomData key="target" value="performance-rating" /></customData>
                        </StandardListItem>
                    </List>
                </VBox>

                <!-- ── Group: Human Resources (hr only) ───────────────────── -->
                <Button class="tsNavGroupHeader tsNavGroupHeaderHr" type="Transparent" width="100%" iconFirst="false"
                    text="Human Resources" press=".onToggleGroup"
                    visible="{= ${appView>/roleResolved} === true &amp;&amp; ${appView>/userRole} === 'hr'}"
                    icon="{= ${side>/hrOpen} ? 'sap-icon://slim-arrow-down' : 'sap-icon://slim-arrow-right' }">
                    <customData><core:CustomData key="group" value="hr" /></customData>
                </Button>
                <VBox id="navHrBody" class="tsNavGroupBody"
                    visible="{= ${appView>/roleResolved} === true &amp;&amp; ${appView>/userRole} === 'hr'}">
                    <List id="navHrList" mode="None" backgroundDesign="Transparent" class="tsNavList">
                        <StandardListItem title="Add Employee" icon="sap-icon://add-employee"
                            type="Active" press=".onNavSelect" class="tsNavItem">
                            <customData><core:CustomData key="target" value="add-employee" /></customData>
                        </StandardListItem>
                        <StandardListItem title="All Employees" icon="sap-icon://employee"
                            type="Active" press=".onNavSelect" class="tsNavItem">
                            <customData><core:CustomData key="target" value="all-employees" /></customData>
                        </StandardListItem>
                        <StandardListItem title="HR Approvals" icon="sap-icon://approvals"
                            type="Active" press=".onNavSelect" class="tsNavItem">
                            <customData><core:CustomData key="target" value="hr-approvals" /></customData>
                        </StandardListItem>
                    </List>
                </VBox>

            </Page>
        </masterPages>

        <detailPages>
            <NavContainer id="detailNav" />
        </detailPages>

    </SplitApp>

</mvc:View>