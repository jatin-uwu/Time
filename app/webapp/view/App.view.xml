<mvc:View
    controllerName="timesheet.app.controller.App"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:core="sap.ui.core"
    displayBlock="true">

<!-- ── Centred loading screen ─────────────────────────────────────
     Visible from the moment the app starts until the backend has
     confirmed the logged-in user's role.  This guarantees the user
     never sees the sidebar in a partially-styled "wrong role"
     intermediate state on first login. -->
<VBox visible="{= !${appView>/roleResolved} }"
      height="100vh"
      justifyContent="Center"
      alignItems="Center"
      class="tsAppLoading">
    <BusyIndicator size="3rem" />
    <Text text="Loading your workspace…" class="sapUiMediumMarginTop tsAppLoadingText" />
</VBox>

<Toolbar visible="{appView>/roleResolved}"
         style="background:#1e293b; min-height:72px; padding:0px 20px; box-shadow:0 2px 12px rgba(0,0,0,0.35);">

    <Button id="menuToggleBtn"
        icon="sap-icon://menu2"
        type="Transparent"
        press=".onMenuToggle"
        style="color:#ffffff; margin-right:8px;" />

    <!-- Logo -->
    <core:HTML sanitizeContent="false" content="
        &lt;div style='display:flex;align-items:center;gap:10px;margin-right:18px;'&gt;
            &lt;img src='./images/companylogo.jpg'
                 style='height:42px;width:auto;object-fit:contain;background:#ffffff;border-radius:6px;padding:3px 6px;'
                 alt='Centrik Logo' /&gt;
        &lt;/div&gt;" />

    <!-- Title + subtitle -->
    <core:HTML sanitizeContent="false" content="
        &lt;div style='
            display:flex;
            flex-direction:column;
            justify-content:center;
            border-left:2px solid #334155;
            padding-left:16px;
        '&gt;
            &lt;span style='
                color:color:#f1f5f9;
                font-size:0.82rem;
                font-weight:800;
                letter-spacing:3.5px;
                font-family: Trebuchet MS, sans-serif;
                text-transform:uppercase;
                line-height:1.2;
            '&gt;DASHBOARD&lt;/span&gt;
            &lt;span style='
                color:#3b82f6;
                font-size:0.68rem;
                font-family:sans-serif;
                letter-spacing:1.5px;
                margin-top:3px;
                font-weight:500;
            '&gt;CCENTRIK INFOTECH PVT. LTD.&lt;/span&gt;
        &lt;/div&gt;" />

    <ToolbarSpacer />
        <!-- Upload profile picture button -->
        <Button
            icon="sap-icon://camera"
            type="Transparent"
            tooltip="Upload profile picture"
            press=".onUploadProfilePicture" />
        <Avatar id="userAvatar"
        src="{appView>/profilePhotoSrc}"
        initials="{= ${appView>/profilePhotoSrc} ? '' : (${appView>/userInitials} || 'JD') }"
        backgroundColor="{= ${appView>/profilePhotoSrc} ? 'Transparent' : 'Accent6' }"
        displaySize="XS"
        press=".onProfilePress"
        tooltip="My profile" />
    </Toolbar>

    <SplitApp id="app" visible="{appView>/roleResolved}">

        <masterPages>
            <Page id="navPage" showHeader="false"
                class="timesheetSidebar"
                backgroundDesign="Transparent">

                <!-- Unified navigation -->
                <List id="mainNavList"
                    mode="None"
                    backgroundDesign="Transparent"
                    style="background:transparent;">
                    <items>
                        <StandardListItem title="Overview"
                            icon="sap-icon://home"
                            type="Active"
                            press=".onNavSelect"
                            style="background:transparent; color:#cbd5e1;">
                            <customData>
                                <core:CustomData key="target" value="dashboard" />
                            </customData>
                        </StandardListItem>
                        <StandardListItem title="Timesheet"
                            icon="sap-icon://calendar"
                            type="Active"
                            press=".onNavSelect"
                            style="background:transparent; color:#cbd5e1;">
                            <customData>
                                <core:CustomData key="target" value="timesheet" />
                            </customData>
                        </StandardListItem>
                        <StandardListItem title="Task Descriptions"
                            icon="sap-icon://wallet"
                            type="Active"
                            press=".onNavSelect"
                            style="background:transparent; color:#cbd5e1;">
                            <customData>
                                <core:CustomData key="target" value="task-description" />
                            </customData>
                        </StandardListItem>
                        <StandardListItem title="Apply Leave"
                            icon="sap-icon://away"
                            type="Active"
                            press=".onNavSelect"
                            style="background:transparent; color:#cbd5e1;">
                            <customData>
                                <core:CustomData key="target" value="apply-leave" />
                            </customData>
                        </StandardListItem>
                        <StandardListItem title="Timesheet History"
                            icon="sap-icon://history"
                            type="Active"
                            press=".onNavSelect"
                            style="background:transparent; color:#cbd5e1;">
                            <customData>
                                <core:CustomData key="target" value="history" />
                            </customData>
                        </StandardListItem>
                        <StandardListItem title="Approvals"
                            icon="sap-icon://approvals"
                            type="Active"
                            press=".onNavSelect"
                            visible="{= ${appView>/roleResolved} === true &amp;&amp; ${appView>/userRole} === 'manager'}"
                            style="background:transparent; color:#cbd5e1;">
                            <customData>
                                <core:CustomData key="target" value="manager" />
                            </customData>
                        </StandardListItem>
                        <StandardListItem title="Assign Task"
                            icon="sap-icon://create-form"
                            type="Active"
                            press=".onNavSelect"
                            visible="{= ${appView>/roleResolved} === true &amp;&amp; ${appView>/userRole} === 'manager'}"
                            style="background:transparent; color:#cbd5e1;">
                            <customData>
                                <core:CustomData key="target" value="task-assignment" />
                            </customData>
                        </StandardListItem>
                        <StandardListItem title="Task Status"
                            icon="sap-icon://activity-items"
                            type="Active"
                            press=".onNavSelect"
                            visible="{= ${appView>/roleResolved} === true &amp;&amp; ${appView>/userRole} === 'manager'}"
                            style="background:transparent; color:#cbd5e1;">
                            <customData>
                                <core:CustomData key="target" value="task-status" />
                            </customData>
                        </StandardListItem>
                        <StandardListItem
                            id="navPerfRating"
                            title="Performance Rating"
                            icon="sap-icon://survey"
                            type="Active"
                            press=".onNavPerfRating"
                            visible="{= ${appView>/roleResolved} === true &amp;&amp; ${appView>/userRole} === 'manager'}"
                            style="background:transparent; color:#cbd5e1;" />
                        <StandardListItem title="Leave Approvals"
                            icon="sap-icon://away"
                            type="Active"
                            press=".onNavSelect"
                            visible="{= ${appView>/roleResolved} === true &amp;&amp; ${appView>/userRole} === 'manager'}"
                            style="background:transparent; color:#cbd5e1;">
                            <customData>
                                <core:CustomData key="target" value="leave-approvals" />
                            </customData>
                        </StandardListItem>
                        <StandardListItem title="Team Attendance"
                            icon="sap-icon://employee-pane"
                            type="Active"
                            press=".onNavSelect"
                            visible="{= ${appView>/roleResolved} === true &amp;&amp; ${appView>/userRole} === 'manager'}"
                            style="background:transparent; color:#cbd5e1;">
                            <customData>
                                <core:CustomData key="target" value="team-attendance" />
                            </customData>
                        </StandardListItem>

                        <!-- HR-only entries -->
                        <StandardListItem title="Add Employee"
                            icon="sap-icon://add-employee"
                            type="Active"
                            press=".onNavSelect"
                            visible="{= ${appView>/roleResolved} === true &amp;&amp; ${appView>/userRole} === 'hr'}"
                            style="background:transparent; color:#cbd5e1;">
                            <customData>
                                <core:CustomData key="target" value="add-employee" />
                            </customData>
                        </StandardListItem>
                        <StandardListItem title="All Employees"
                            icon="sap-icon://employee"
                            type="Active"
                            press=".onNavSelect"
                            visible="{= ${appView>/roleResolved} === true &amp;&amp; ${appView>/userRole} === 'hr'}"
                            style="background:transparent; color:#cbd5e1;">
                            <customData>
                                <core:CustomData key="target" value="all-employees" />
                            </customData>
                        </StandardListItem>
                    </items>
                </List>

                <!-- Empty placeholder kept so existing code referencing managerNavList still
                resolves safely -->
                <List id="managerNavList"
                    mode="None"
                    backgroundDesign="Transparent"
                    visible="false"
                    style="background:transparent;" />

            </Page>
        </masterPages>

        <detailPages>
            <NavContainer id="detailNav" />
        </detailPages>

    </SplitApp>

</mvc:View>