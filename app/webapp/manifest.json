{
    "_version": "1.58.0",
    "sap.app": {
        "id":          "timesheet.app",
        "type":        "application",
        "title":       "Timesheet",
        "description": "Weekly Timesheet Dashboard",
        "dataSources": {
            "TimesheetService": {
                "uri":  "/employee/",
                "type": "OData",
                "settings": { "odataVersion": "4.0" }
            },
            "ManagerService": {
                "uri":  "/manager/",
                "type": "OData",
                "settings": { "odataVersion": "4.0" }
            },
            "HRService": {
                "uri":  "/hr/",
                "type": "OData",
                "settings": { "odataVersion": "4.0" }
            }
        }
    },
    "sap.ui": {
        "technology":  "UI5",
        "deviceTypes": { "desktop": true, "tablet": true, "phone": false }
    },
    "sap.ui5": {
        "rootView": {
            "viewName": "timesheet.app.view.App",
            "type":     "XML",
            "id":       "AppView"
        },
        "dependencies": {
            "minUI5Version": "1.120.0",
            "libs": {
                "sap.ui.core":    {},
                "sap.m":          {},
                "sap.f":          {},
                "sap.ui.layout":  {},
                "sap.ui.table":   {},
                "sap.ui.unified": {},
                "sap.uxap":       {}
            }
        },
        "models": {
            "": {
                "dataSource":  "TimesheetService",
                "preload":     true,
                "settings": {
                    "synchronizationMode": "None",
                    "operationMode":       "Server",
                    "autoExpandSelect":    true
                }
            },
            "manager": {
                "dataSource":  "ManagerService",
                "preload":     true,
                "settings": {
                    "synchronizationMode": "None",
                    "operationMode":       "Server",
                    "autoExpandSelect":    true
                }
            },
            "hr": {
                "dataSource":  "HRService",
                "preload":     true,
                "settings": {
                    "synchronizationMode": "None",
                    "operationMode":       "Server",
                    "autoExpandSelect":    true
                }
            },
            "view": {
                "type":    "sap.ui.model.json.JSONModel",
                "settings": { "data": {} }
            },
            "rows": {
                "type":    "sap.ui.model.json.JSONModel",
                "settings": { "data": { "rows": [] } }
            },
            "i18n": {
                "type":    "sap.ui.model.resource.ResourceModel",
                "settings": { "bundleName": "timesheet.app.i18n.i18n" }
            }
        },
        "routing": {
            "config": {
                "routerClass":        "sap.m.routing.Router",
                "viewType":           "XML",
                "viewPath":           "timesheet.app.view",
                "controlAggregation": "pages",
                "controlId":          "detailNav",
                "transition":         "slide"
            },
            "routes": [
                { "name": "dashboard",     "pattern": "",              "target": "dashboard"     },
                { "name": "timesheet",     "pattern": "timesheet",     "target": "timesheet"     },
                { "name": "task-description", "pattern": "task-description", "target": "task-description" },
                { "name": "task-detail",   "pattern": "task-detail/{taskId}", "target": "task-detail" },
                { "name": "history",       "pattern": "history",       "target": "history"       },
                { "name": "manager",       "pattern": "manager",       "target": "manager"       },
                { "name": "task-assignment", "pattern": "task-assignment", "target": "task-assignment" },
                { "name": "task-status",   "pattern": "task-status",   "target": "task-status"   },
                { "name": "notifications", "pattern": "notifications", "target": "notifications" },
                { "name": "add-employee",  "pattern": "add-employee",  "target": "add-employee"  },
                { "name": "all-employees", "pattern": "all-employees", "target": "all-employees" }
            ],
            "targets": {
                "dashboard":     { "viewName": "Dashboard",     "viewId": "dashboard"     },
                "timesheet":     { "viewName": "Timesheet",     "viewId": "timesheet"     },
                "task-description": { "viewName": "TaskDescription", "viewId": "task-description" },
                "task-detail":   { "viewName": "TaskDetail",   "viewId": "task-detail"   },
                "history":       { "viewName": "History",       "viewId": "history"       },
                "manager":       { "viewName": "Manager",       "viewId": "manager"       },
                "task-assignment": { "viewName": "TaskAssignment", "viewId": "task-assignment" },
                "task-status":   { "viewName": "TaskStatus",   "viewId": "task-status"   },
                "notifications": { "viewName": "Notifications", "viewId": "notifications" },
                "add-employee":  { "viewName": "AddEmployee",   "viewId": "add-employee"  },
                "all-employees": { "viewName": "AllEmployees",  "viewId": "all-employees" }
            }
        }
    }
}
