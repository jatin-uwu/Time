{
    "_version": "1.58.0",
    "sap.app": {
        "id":          "timesheet.app",
        "type":        "application",
        "title":       "Employee Dashboard",
        "description": "Present Employee Dashboard",
        "dataSources": {
            "TimesheetService": {
                "uri":  "/employee/",
                "type": "OData",
                "settings": { "odataVersion": "4.0" }
            },
            "ManagerService": {
                "uri":  "/manager/",
                "type": "OData",
                "settings": { "odataVersion": "4.0" }
            },
            "HRService": {
                "uri":  "/hr/",
                "type": "OData",
                "settings": { "odataVersion": "4.0" }
            }
        }
    },
    "sap.ui": {
        "technology":  "UI5",
        "deviceTypes": { "desktop": true, "tablet": true, "phone": false }
    },
    "sap.ui5": {
        "rootView": {
            "viewName": "timesheet.app.view.App",
            "type":     "XML",
            "id":       "AppView"
        },
        "dependencies": {
            "minUI5Version": "1.120.0",
            "libs": {
                "sap.ui.core":    {},
                "sap.m":          {},
                "sap.f":          {},
                "sap.ui.layout":  {},
                "sap.ui.table":   {},
                "sap.ui.unified": {},
                "sap.uxap":       {}
            }
        },
        "resources": {
            "css": [
                { "uri": "css/style.css?v=25" }
            ]
        },
        "models": {
            "": {
                "dataSource":  "TimesheetService",
                "preload":     true,
                "settings": {
                    "synchronizationMode": "None",
                    "operationMode":       "Server",
                    "autoExpandSelect":    false
                }
            },
            "manager": {
                "dataSource":  "ManagerService",
                "preload":     true,
                "settings": {
                    "synchronizationMode": "None",
                    "operationMode":       "Server",
                    "autoExpandSelect":    true
                }
            },
            "hr": {
                "dataSource":  "HRService",
                "preload":     true,
                "settings": {
                    "synchronizationMode": "None",
                    "operationMode":       "Server",
                    "autoExpandSelect":    true
                }
            },
            "view": {
                "type":    "sap.ui.model.json.JSONModel",
                "settings": { "data": {} }
            },
            "rows": {
                "type":    "sap.ui.model.json.JSONModel",
                "settings": { "data": { "rows": [] } }
            },
            "i18n": {
                "type":    "sap.ui.model.resource.ResourceModel",
                "settings": { "bundleName": "timesheet.app.i18n.i18n" }
            }
        },
        "routing": {
            "config": {
                "routerClass":        "sap.m.routing.Router",
                "viewType":           "XML",
                "viewPath":           "timesheet.app.view",
                "controlAggregation": "pages",
                "controlId":          "detailNav",
                "transition":         "slide",
                "clearControlAggregation": false
            },
            "routes": [
                { "name": "dashboard",     "pattern": "",              "target": "dashboard"     },
                { "name": "timesheet",     "pattern": "timesheet",     "target": "timesheet"     },
                { "name": "task-description", "pattern": "task-description", "target": "task-description" },
                { "name": "task-detail",   "pattern": "task-detail/{taskId}", "target": "task-detail" },
                { "name": "history",       "pattern": "history",       "target": "history"       },
                { "name": "manager",       "pattern": "manager",       "target": "manager"       },
                { "name": "task-assignment", "pattern": "task-assignment", "target": "task-assignment" },
                { "name": "task-status",   "pattern": "task-status",   "target": "task-status"   },
                { "name": "team-task-status", "pattern": "team-task-status", "target": "team-task-status" },
                { "name": "group-tasks",   "pattern": "group-tasks",   "target": "group-tasks"   },
                { "name": "group-task-detail", "pattern": "group-task-detail/{taskId}", "target": "group-task-detail" },
                { "name": "notifications", "pattern": "notifications", "target": "notifications" },
                { "name": "add-employee",  "pattern": "add-employee",  "target": "add-employee"  },
                { "name": "all-employees", "pattern": "all-employees", "target": "all-employees" },
                { "name": "apply-leave", "pattern": "apply-leave", "target": "apply-leave" },
                { "name": "leave-approvals", "pattern": "leave-approvals", "target": "leave-approvals" },
                { "name": "performance-rating", "pattern": "performance-rating", "target": "performance-rating" },
                { "name": "team-attendance", "pattern": "team-attendance", "target": "team-attendance" },
                { "name": "approval-history", "pattern": "approval-history", "target": "approval-history" },
                { "name": "leave-history", "pattern": "leave-history", "target": "leave-history" },
                { "name": "rating-history", "pattern": "rating-history", "target": "rating-history" },
                { "name": "hr-approvals", "pattern": "hr-approvals", "target": "hr-approvals" }
            ],
            "targets": {
                "dashboard":     { "viewName": "Dashboard"     },
                "timesheet":     { "viewName": "Timesheet"    },
                "task-description": { "viewName": "TaskDescription" },
                "task-detail":   { "viewName": "TaskDetail"},
                "history":       { "viewName": "History"      },
                "manager":       { "viewName": "Manager"    },
                "task-assignment": { "viewName": "TaskAssignment"},
                "task-status":   { "viewName": "TaskStatus" },
                "team-task-status": { "viewName": "TeamTaskStatus" },
                "group-tasks":   { "viewName": "GroupTasks" },
                "group-task-detail": { "viewName": "GroupTaskDetail" },
                "notifications": { "viewName": "Notifications"},
                "add-employee":  { "viewName": "AddEmployee" },
                "all-employees": { "viewName": "AllEmployees"},
                "apply-leave": { "viewName": "ApplyLeave" },
                "leave-approvals":{ "viewName": "LeaveApprovals"},
                "performance-rating": { "viewName": "PerformanceRating" },
                "team-attendance": { "viewName": "TeamAttendance" },
                "approval-history": { "viewName": "ApprovalHistory" },
                "leave-history":  { "viewName": "LeaveHistory" },
                "rating-history": { "viewName": "RatingHistory" },
                "hr-approvals":   { "viewName": "HrApproval" }
            }
        }
    }
}
