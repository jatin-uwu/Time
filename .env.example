# ─────────────────────────────────────────────────────────────────────────────
# Email (SMTP) configuration for the Email Notification module.
# Copy this file to ".env" and fill in real values. NEVER commit the real .env.
# CAP auto-loads .env in development; on BTP set these as service/user-provided vars.
# ─────────────────────────────────────────────────────────────────────────────

# ── SMTP (required to actually send; if unset, emails are simulated + logged) ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
# SMTP_SECURE=false            # true only for port 465 (implicit TLS); 587 uses STARTTLS
SMTP_USER=you@yourcompany.com
# Gmail: create an APP PASSWORD (Google Account → Security → 2-Step → App passwords).
# Do NOT use your normal login password.
SMTP_PASS=your_app_password
SMTP_FROM=Ccentrik PM <you@yourcompany.com>

# Master switch — set to false to disable real sending (emails simulate + log).
EMAIL_ENABLED=true

# ── Branding used in every email template (no hardcoding in code) ─────────────
COMPANY_NAME=Ccentrik
# Absolute URL to a hosted logo (email clients can't load relative paths). Optional.
COMPANY_LOGO_URL=
COMPANY_SUPPORT_EMAIL=support@yourcompany.com
BRAND_COLOR=#4338ca
# Base URL of the app, used for "Open" buttons/links in emails.
APP_URL=http://localhost:4004/webapp/index.html
