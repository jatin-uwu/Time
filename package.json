{
  "name": "Timesheet",
  "version": "1.0.0",
  "engines": {
    "node": "^20.0.0"
  },
  "dependencies": {
    "@cap-js/hana": "^2",
    "@sap/cds": "^9",
    "@sap/xssec": "^4",
    "nodemailer": "^8.0.7"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2",
    "@sap/cds-dk": "^9"
  },
  "scripts": {
    "start": "cds-serve"
  },
  "private": true,
  "cds": {
    "requires": {
      "db": {
        "[development]": {
          "kind": "sqlite",
          "credentials": {
            "database": "db.sqlite"
          }
        },
        "[production]": {
          "kind": "hana"
        }
      },
      "auth": {
        "[production]": {
          "strategy": "JWT"
        },
        "[development]": {
          "strategy": "mocked",
          "users": {
            "jatin": {
              "password": "jatin",
              "roles": ["Manager", "Employee"],
              "attr": {
                "email": "jatin.bajaj@ccentrik.com"
              }
            },
            "punit": {
              "password": "punit",
              "roles": ["HR", "Employee"],
              "attr": {
                "email": "punit.sharma@ccentrik.com"
              }
            },
            "neha": {
              "password": "neha",
              "roles": ["Employee"],
              "attr": {
                "email": "neha.kapoor@ccentrik.com"
              }
            },
            "ankit": {
              "password": "ankit",
              "roles": ["Employee"],
              "attr": {
                "email": "ankit.verma@ccentrik.com"
              }
            },
            "vineet": {
              "password": "vineet",
              "roles": ["Manager", "Employee"],
              "attr": {
                "email": "vineet@ccentrik.com"
              }
            },
            "founder": {
              "password": "founder",
              "roles": ["Manager"],
              "attr": {
                "email": "founder@ccentrik.com"
              }
            }
          }
        }
      },
      "[production]": {
        "auth": {
          "kind": "xsuaa"
        }
      }
    }
  }
}