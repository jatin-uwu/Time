{
  "name": "Timesheet",
  "version": "1.0.0",
  "engines": {
    "node": "^20.0.0"
  },
  "dependencies": {
    "@cap-js/hana": "^2",
    "@sap/cds": "^9",
    "@sap/xssec": "^4",
    "nodemailer": "^8.0.7"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2",
    "@sap/cds-dk": "^9"
  },
  "scripts": {
    "start": "cds-serve"
  },
  "private": true,
  "cds": {
    "requires": {
      "auth": {
        "[production]": {
          "strategy": "JWT"
        },
        "[development]": {
          "strategy": "mocked",
          "users": {
            "jatin": {
              "roles": [
                "Manager",
                "Employee"
              ]
            },
            "punit": {
              "password": "punit",
              "roles": ["HR"]
            },
            "Neha": {
              "roles": [
                "Employee"
              ]
            },
            "Founder": {
              "roles": [
                "Manager"
              ]
            },
            "hr1": {
              "roles": [
                "HR",
                "Employee"
              ]
            }
          }
        }
      },
      "[production]": {
        "auth": {
          "kind": "xsuaa"
        }
      }
    }
  }
}
